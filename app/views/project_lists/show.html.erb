<% set_meta_tags title: @project_list.name.presence || t("views.project_lists.show.default_title") %>

<div class="max-w-3xl mx-auto pt-6 pb-12 px-4 sm:px-6 lg:px-8"
  data-controller="project-list"
  data-project-list-slug-value="<%= @project_list.slug %>"
  data-project-list-locale-value="<%= I18n.locale %>">
  <div class="flex justify-between items-start">
    <div>
      <h1 class="text-3xl font-bold">
        <%= @project_list.name.presence || t("views.project_lists.show.default_title") %>
      </h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1">
        <%= t("views.project_lists.show.problem_count", count: @project_list.problem_ids.size) %>
      </p>
    </div>
  </div>

  <%# Rename form %>
  <details class="mt-4">
    <summary class="text-sm text-emerald-600 cursor-pointer"><%= t("views.project_lists.show.rename") %></summary>
    <%= form_with url: project_list_path(@project_list), method: :patch, class: "mt-2 flex items-center space-x-2" do |f| %>
      <%= f.text_field :name, value: @project_list.name, placeholder: t("views.project_lists.show.name_placeholder"), class: "border border-gray-300 dark:border-gray-600 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
      <%= f.submit t("views.project_lists.show.save"), class: "bg-emerald-600 text-white px-3 py-1.5 rounded-md text-sm hover:bg-emerald-700 cursor-pointer" %>
    <% end %>
  </details>

  <%# Share link %>
  <div class="mt-4 flex items-center space-x-2">
    <span class="text-sm text-gray-500 dark:text-gray-400"><%= t("views.project_lists.show.share") %></span>
    <input type="text" value="<%= request.original_url %>" readonly
      class="text-sm border border-gray-300 dark:border-gray-600 rounded-md px-2 py-1 bg-gray-50 dark:bg-gray-800 flex-1"
      onclick="this.select()">
  </div>

  <%# Problem list %>
  <% if @project_list.problems.any? %>
    <ul class="mt-6 divide-y divide-gray-100 dark:divide-gray-700">
      <% @project_list.problems.each do |problem| %>
        <li class="flex justify-between items-center py-3">
          <%= link_to problem_friendly_path(problem), class: "flex-1 flex items-center space-x-3" do %>
            <%= problem_circle_view(problem) %>
            <div>
              <span class="font-medium"><%= problem.name_with_fallback %></span>
              <span class="ml-2 text-gray-500 dark:text-gray-400"><%= problem.grade %></span>
              <span class="ml-2 text-gray-400 dark:text-gray-500 text-sm"><%= problem.area.name %></span>
            </div>
          <% end %>
          <%= button_to project_list_path(@project_list, remove_problem_id: problem.id),
            method: :patch,
            class: "text-gray-400 dark:text-gray-500 hover:text-red-500 ml-2" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="mt-8 text-center text-gray-400 dark:text-gray-500">
      <p><%= t("views.project_lists.show.empty") %></p>
    </div>
  <% end %>
</div>
