<% set_meta_tags title: t("views.steepnesses.index.metas.title") %>
<% set_meta_tags og: { type: "website", image: image_url("hero-homepage.jpg") } %>

<div class="max-w-7xl mx-auto pt-6 sm:px-6 lg:px-8">
  <div class="px-4 sm:px-0">
    <div class="flex items-center space-x-1 text-sm font-medium text-gray-500 dark:text-gray-400">
      <div><%= link_to "Fontainebleau", areas_path, class: "hover:text-gray-700 dark:hover:text-gray-300" %></div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 mb-8">
  <h1 class="text-3xl font-bold mt-2 mb-4 px-4 sm:px-0"><%= t("views.steepnesses.index.title") %></h1>
  <div class="lg:grid lg:grid-cols-2 lg:gap-16 mt-4">
    <div class="col-span-1">
      <%= form_with url: steepnesses_path, method: :get, class: "px-4 sm:px-0 space-y-4" do |form| %>
        <div>
          <label for="grade_level" class="block text-sm font-medium text-gray-700 dark:text-gray-300"><%= t("views.steepnesses.index.grade_label") %></label>
          <%= form.select :grade_level, SteepnessesController::GRADE_LEVELS.map { |v| [t("views.steepnesses.index.grade_levels.#{v}"), v] }, { selected: @grade_level, include_blank: t("views.steepnesses.index.all") }, { onchange: 'this.form.submit()', class: "mt-1 block w-full md:w-1/3 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm" } %>
        </div>

        <div>
          <label for="steepness" class="block text-sm font-medium text-gray-700 dark:text-gray-300"><%= t("views.steepnesses.index.steepness_label") %></label>
          <%= form.select :steepness, SteepnessesController::ALLOWED_VALUES.map { |v| [t("problem.steepness.#{v}"), v] }, { selected: @steepness, include_blank: t("views.steepnesses.index.all") }, { onchange: 'this.form.submit()', class: "mt-1 block w-full md:w-1/3 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm" } %>
        </div>

        <% unless @circuit_id.present? %>
          <div>
            <label for="sort" class="block text-sm font-medium text-gray-700 dark:text-gray-300"><%= t("views.steepnesses.index.sort_label") %></label>
            <div class="flex items-center space-x-2 mt-1">
              <%= form.select :sort, SteepnessesController::SORT_OPTIONS.map { |v| [t("views.steepnesses.index.sort_options.#{v}"), v] }, { selected: @sort }, { onchange: 'this.form.submit()', class: "block w-full md:w-1/3 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm" } %>
              <%= form.hidden_field :direction, value: @direction, id: "direction_field" %>
              <button type="submit" onclick="var f = document.getElementById('direction_field'); f.value = f.value === 'asc' ? 'desc' : 'asc';" class="inline-flex items-center p-2 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400" title="<%= @direction == :asc ? t("views.steepnesses.index.ascending") : t("views.steepnesses.index.descending") %>">
                <% if @direction == :asc %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
                  </svg>
                <% else %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h9m5-4v12m0 0l-4-4m4 4l4-4" />
                  </svg>
                <% end %>
              </button>
            </div>
          </div>
        <% end %>

        <div>
          <label for="circuit_id" class="block text-sm font-medium text-gray-700 dark:text-gray-300"><%= t("views.steepnesses.index.circuit_label") %></label>
          <%= form.select :circuit_id, @circuits.map { |c| ["#{c.main_area&.name} – #{c.name}", c.id] }, { selected: @circuit_id, include_blank: t("views.steepnesses.index.all") }, { onchange: 'this.form.submit()', class: "mt-1 block w-full md:w-1/2 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm" } %>
        </div>
      <% end %>

      <h2 class="text-xl font-bold mb-2 pt-8 px-4 sm:px-0"></h2>
      <ul role="list">
        <% @problems.each do |problem| %>
          <li class="px-4 sm:-mx-2 sm:px-2 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg">
            <%= link_to problem_friendly_path(problem) do %>
              <div class="py-2">
                <div>
                  <span><%= problem.name_with_fallback %></span>
                  <span class="ml-1 text-gray-500 dark:text-gray-400"><%= problem.grade %></span>
                </div>
                <div class="flex flex-wrap items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400 mt-1">
                  <% if problem.popularity.present? && problem.popularity > 0 %>
                    <span class="inline-flex items-center gap-1 rounded-full bg-gray-200 dark:bg-gray-700 px-2 py-0.5" title="<%= t("views.steepnesses.index.popularity") %>">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                      <%= problem.popularity %>
                    </span>
                  <% end %>
                  <span class="inline-flex items-center rounded-full bg-gray-200 dark:bg-gray-700 px-2 py-0.5"><%= t("problem.steepness.#{problem.steepness}") %></span>
                  <span class="inline-flex items-center rounded-full bg-gray-200 dark:bg-gray-700 px-2 py-0.5"><%= problem.area.name %></span>
                  <% if problem.circuit.present? %>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5" style="background-color: <%= uicolor(problem.circuit.color) %>; color: <%= text_color(problem.circuit.color) %>"><%= problem.circuit.name %><%= " #{problem.circuit_number}" if problem.circuit_number.present? %></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
