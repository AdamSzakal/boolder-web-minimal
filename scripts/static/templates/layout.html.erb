<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= [page_title, "Boolder"].compact.join(" — ") %></title>

    <link rel="stylesheet" href="/assets/tailwind.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
      /* Oxocarbon color scheme + IBM Plex Sans */
      body { font-family: 'IBM Plex Sans', sans-serif; font-size: 14px; }

      /* Light mode overrides */
      .bg-gray-100 { background-color: #f2f4f8 !important; }
      .bg-gray-50 { background-color: #f2f4f8 !important; }
      .text-gray-900 { color: #161616 !important; }
      .text-gray-700 { color: #262626 !important; }
      .text-gray-500 { color: #525252 !important; }
      .text-gray-400 { color: #697077 !important; }
      .border-gray-200 { border-color: #dde1e6 !important; }
      .border-gray-300 { border-color: #dde1e6 !important; }
      .bg-emerald-600 { background-color: #be95ff !important; }
      .hover\:bg-emerald-500:hover { background-color: #a56eff !important; }
      .text-emerald-700 { color: #be95ff !important; }
      .bg-emerald-50 { background-color: rgba(190, 149, 255, 0.1) !important; }
      .text-emerald-300 { color: #be95ff !important; }
      .hover\:text-emerald-600:hover { color: #be95ff !important; }
      .text-emerald-600 { color: #be95ff !important; }

      /* Dark mode overrides */
      @media (prefers-color-scheme: dark) {
        .dark\:bg-gray-900 { background-color: #161616 !important; }
        .dark\:bg-gray-800 { background-color: #262626 !important; }
        .dark\:bg-gray-700 { background-color: #393939 !important; }
        .dark\:text-gray-100 { color: #f2f4f8 !important; }
        .dark\:text-gray-300 { color: #dde1e6 !important; }
        .dark\:text-gray-400 { color: #697077 !important; }
        .dark\:text-gray-500 { color: #525252 !important; }
        .dark\:border-gray-600 { border-color: #393939 !important; }
        .dark\:border-gray-700 { border-color: #393939 !important; }
        .dark\:shadow-gray-700\/50 { --tw-shadow-color: rgba(57,57,57,0.5) !important; }
        .dark\:hover\:text-gray-100:hover { color: #f2f4f8 !important; }
        .dark\:hover\:bg-gray-700:hover { background-color: #393939 !important; }
        .dark\:hover\:bg-gray-800:hover { background-color: #262626 !important; }
        .dark\:hover\:text-emerald-400:hover { color: #be95ff !important; }
        .dark\:bg-emerald-900\/30 { background-color: rgba(190, 149, 255, 0.15) !important; }
        .dark\:text-emerald-300 { color: #be95ff !important; }
      }
    </style>

    <!-- Project list localStorage API (in head so page scripts can use it) -->
    <script>
    var BoolderProjects = (function() {
      var KEY = 'boolder_projects';

      function getIds() {
        try {
          return JSON.parse(localStorage.getItem(KEY)) || [];
        } catch(e) { return []; }
      }

      function saveIds(ids) {
        localStorage.setItem(KEY, JSON.stringify(ids));
      }

      return {
        list: getIds,
        has: function(id) { return getIds().indexOf(id) !== -1; },
        add: function(id) {
          var ids = getIds();
          if (ids.indexOf(id) === -1) { ids.push(id); saveIds(ids); }
        },
        remove: function(id) {
          saveIds(getIds().filter(function(x) { return x !== id; }));
        },
        toggle: function(id) {
          if (this.has(id)) { this.remove(id); return false; }
          else { this.add(id); return true; }
        },
        addAll: function(newIds) {
          var ids = getIds();
          newIds.forEach(function(id) { if (ids.indexOf(id) === -1) ids.push(id); });
          saveIds(ids);
        },
        clear: function() { localStorage.removeItem(KEY); }
      };
    })();
    </script>
  </head>

  <body class="bg-white dark:bg-gray-900">
    <div class="bg-gray-100 dark:bg-gray-800">

      <!-- Nav -->
      <nav class="bg-white dark:bg-gray-900 shadow dark:shadow-gray-700/50">
        <div class="max-w-7xl mx-auto px-2 sm:px-4 lg:px-8">
          <div class="flex justify-between h-12">
            <div class="flex items-center px-2 lg:px-0 space-x-4">
              <a href="/en/fontainebleau" class="text-xl flex-shrink-0" aria-label="Boolder">🍷</a>
              <a href="/en/fontainebleau" class="text-sm font-normal text-gray-900 dark:text-gray-100">Areas</a>
              <a href="/en/fontainebleau/boulders" class="text-sm font-normal text-gray-900 dark:text-gray-100">Boulders</a>
              <a href="/en/map" class="text-sm font-normal text-gray-900 dark:text-gray-100">Map</a>
              <a href="/en/projects" class="text-sm font-normal text-gray-900 dark:text-gray-100">Ticks</a>
            </div>
            <div class="flex items-center pr-2 lg:pr-0">
              <button type="button" id="searchOpenBtn" class="p-1 text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100" aria-label="Open search">
                <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>
          </div>
        </div>
      </nav>

      <!-- Search modal -->
      <div id="searchModal" class="fixed inset-0 z-50 hidden overflow-y-auto" role="dialog" aria-modal="true">
        <div class="flex justify-center pt-4 px-1 pb-20 text-center sm:block sm:p-0">
          <div id="searchBackdrop" class="fixed inset-0 transition-opacity" aria-hidden="true">
            <div class="absolute inset-0 bg-gray-600 sm:bg-gray-400 opacity-75 sm:opacity-50"></div>
          </div>
          <div class="inline-block align-bottom bg-white dark:bg-gray-900 rounded-lg text-left overflow-hidden shadow-xl transform transition-all w-full max-w-md sm:max-w-lg sm:align-middle sm:my-8 sm:w-full sm:rounded-xl sm:shadow-2xl">
            <div class="relative">
              <svg class="pointer-events-none absolute left-4 top-3.5 h-5 w-5 text-emerald-700" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
              </svg>
              <div class="flex items-center">
                <input
                  type="text"
                  id="searchInput"
                  class="h-12 w-full border-0 bg-transparent pl-11 pr-4 text-gray-900 dark:text-gray-100 placeholder:text-gray-500 focus:ring-0 focus:outline-none"
                  placeholder="Search areas and boulders..."
                  autocorrect="off"
                  autocomplete="off"
                  spellcheck="false"
                >
                <button id="searchClearBtn" type="button" class="hidden h-12 w-12 flex items-center justify-center text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100" aria-label="Clear">&#10005;</button>
                <button id="searchCancelBtn" type="button" class="h-12 px-4 inline-flex justify-center items-center border-l border-l-gray-300 dark:border-l-gray-600 font-medium bg-white dark:bg-gray-900 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-gray-700">
                  Cancel
                </button>
              </div>
            </div>
            <ul id="searchResults" class="bg-gray-100 dark:bg-gray-800 cursor-pointer max-h-80 overflow-y-auto border-t border-gray-200 dark:border-gray-700 pb-2 hidden">
            </ul>
          </div>
        </div>
      </div>

      <!-- Content -->
      <%= content %>

      <footer class="bg-white dark:bg-gray-900 border-t border-gray-200 dark:border-gray-700">
        <div class="max-w-7xl mx-auto py-4 px-4 overflow-hidden sm:px-6 lg:px-8">
          <div class="flex justify-center">
            <nav class="flex flex-wrap justify-center" aria-label="Footer">
              <div class="px-4 py-2">
                <a href="https://www.boolder.com" class="text-base text-gray-400 dark:text-gray-500 hover:text-gray-900 dark:hover:text-gray-100">Boolder</a>
              </div>
            </nav>
          </div>
        </div>
      </footer>
    </div>

    <script>
    (function() {
      var modal = document.getElementById('searchModal');
      var input = document.getElementById('searchInput');
      var results = document.getElementById('searchResults');
      var clearBtn = document.getElementById('searchClearBtn');
      var cancelBtn = document.getElementById('searchCancelBtn');
      var backdrop = document.getElementById('searchBackdrop');
      var openBtn = document.getElementById('searchOpenBtn');
      var index = null;
      var activeIdx = -1;

      var colorHex = {yellow:"#FFCC02",purple:"#D783FF",orange:"#FF9500",green:"#77C344",blue:"#017AFF",skyblue:"#5AC7FA",salmon:"#FDAF8A",red:"#FF3B2F",black:"#000000",white:"#FFFFFF"};

      // Lazy-load search index
      function ensureIndex(cb) {
        if (index) return cb();
        fetch('/assets/search-index.json').then(function(r) { return r.json(); }).then(function(data) {
          index = data;
          cb();
        });
      }

      function normalize(str) {
        if (!str) return '';
        return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-zA-Z0-9]/g, '').toLowerCase();
      }

      function openModal() {
        modal.classList.remove('hidden');
        input.value = '';
        results.classList.add('hidden');
        results.innerHTML = '';
        clearBtn.classList.add('hidden');
        activeIdx = -1;
        input.focus();
        ensureIndex(function() {});
      }

      function closeModal() {
        modal.classList.add('hidden');
        input.value = '';
        results.classList.add('hidden');
        results.innerHTML = '';
        activeIdx = -1;
      }

      function search() {
        var q = normalize(input.value.trim());
        if (!q || !index) {
          results.classList.add('hidden');
          results.innerHTML = '';
          clearBtn.classList.add('hidden');
          activeIdx = -1;
          return;
        }
        clearBtn.classList.remove('hidden');

        // Fuzzy: split query into tokens, all must match
        var tokens = q.match(/[a-z0-9]+/g) || [q];

        var areaHits = index.areas.filter(function(a) {
          return tokens.every(function(t) { return a.n.indexOf(t) !== -1; });
        });

        var problemHits = index.problems.filter(function(p) {
          return tokens.every(function(t) { return p.n.indexOf(t) !== -1; });
        });
        problemHits.sort(function(a, b) { return (b.pop || 0) - (a.pop || 0); });
        problemHits = problemHits.slice(0, 20);

        var items = [];
        areaHits.forEach(function(a) { items.push({type:'area', name:a.name, url:a.url}); });
        problemHits.forEach(function(p) {
          items.push({type:'problem', name:p.name, grade:p.grade, area:p.area, cc:p.cc, cn:p.cn, url:p.url});
        });

        if (items.length === 0) {
          results.classList.add('hidden');
          results.innerHTML = '';
          activeIdx = -1;
          return;
        }

        results.innerHTML = items.map(function(item, i) {
          if (item.type === 'area') {
            return '<li class="px-4 py-2 hover:bg-emerald-50 dark:hover:bg-gray-700" data-url="' + esc(item.url) + '" data-i="' + i + '">' +
              '<span class="font-medium">' + esc(item.name) + '</span>' +
              '<span class="ml-2 text-xs text-gray-400">Area</span>' +
            '</li>';
          }
          var bg = colorHex[item.cc] || 'rgb(80%,80%,80%)';
          var fg = item.cc === 'white' ? '#333' : '#FFF';
          var circle = item.cc
            ? '<span class="inline-flex items-center justify-center w-5 h-5 rounded-full text-xs font-bold mr-2" style="background:' + bg + ';color:' + fg + ';">' + (item.cn || '') + '</span>'
            : '';
          return '<li class="px-4 py-2 hover:bg-emerald-50 dark:hover:bg-gray-700" data-url="' + esc(item.url) + '" data-i="' + i + '">' +
            '<div class="flex justify-between items-center">' +
              '<div class="flex items-center">' + circle +
                '<span>' + esc(item.name) + '</span>' +
                '<span class="ml-2 text-gray-400">' + (item.grade || '') + '</span>' +
              '</div>' +
              '<span class="text-xs text-gray-400">' + esc(item.area) + '</span>' +
            '</div>' +
          '</li>';
        }).join('');

        results.classList.remove('hidden');
        activeIdx = -1;
      }

      function setActive(i) {
        var lis = results.querySelectorAll('li');
        lis.forEach(function(li) { li.style.backgroundColor = ''; });
        activeIdx = i;
        if (activeIdx >= 0 && activeIdx < lis.length) {
          var isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          lis[activeIdx].style.backgroundColor = isDark ? '#374151' : '#d1fae5';
          lis[activeIdx].scrollIntoView({block:'nearest'});
        }
      }

      function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      // Events
      openBtn.addEventListener('click', openModal);
      backdrop.addEventListener('click', closeModal);
      cancelBtn.addEventListener('click', closeModal);
      clearBtn.addEventListener('click', function() {
        input.value = '';
        input.focus();
        results.classList.add('hidden');
        results.innerHTML = '';
        clearBtn.classList.add('hidden');
        activeIdx = -1;
      });

      input.addEventListener('input', search);

      input.addEventListener('keydown', function(e) {
        var lis = results.querySelectorAll('li');
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(Math.min(activeIdx + 1, lis.length - 1));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(Math.max(activeIdx - 1, 0));
        } else if (e.key === 'Enter' && activeIdx >= 0 && activeIdx < lis.length) {
          e.preventDefault();
          window.location = lis[activeIdx].getAttribute('data-url');
        } else if (e.key === 'Escape') {
          closeModal();
        }
      });

      results.addEventListener('click', function(e) {
        var li = e.target.closest('li');
        if (li && li.getAttribute('data-url')) {
          window.location = li.getAttribute('data-url');
        }
      });

      // Keyboard shortcut: "/" to open search
      document.addEventListener('keydown', function(e) {
        if (e.key === '/' && !modal.classList.contains('hidden') === false && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA' && document.activeElement.tagName !== 'SELECT') {
          e.preventDefault();
          openModal();
        }
      });
    })();
    </script>

  </body>
</html>
