<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= [page_title, "Boolder"].compact.join(" — ") %></title>

    <link rel="stylesheet" href="/assets/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Shared constants from ViewHelpers (single source of truth for JS) -->
    <script>
    window.BOOLDER_COLOR_HEX = <%= Static::ViewHelpers.color_hex_json %>;
    window.BOOLDER_STEEPNESS_LABELS = <%= Static::ViewHelpers.steepness_labels_json %>;
    </script>

    <!-- Project list localStorage API (in head so page scripts can use it) -->
    <script>
    var BoolderProjects = (function() {
      var KEY = 'boolder_projects';

      function getIds() {
        try {
          return JSON.parse(localStorage.getItem(KEY)) || [];
        } catch(e) { return []; }
      }

      function saveIds(ids) {
        localStorage.setItem(KEY, JSON.stringify(ids));
      }

      return {
        list: getIds,
        has: function(id) { return getIds().indexOf(id) !== -1; },
        add: function(id) {
          var ids = getIds();
          if (ids.indexOf(id) === -1) { ids.push(id); saveIds(ids); }
        },
        remove: function(id) {
          saveIds(getIds().filter(function(x) { return x !== id; }));
        },
        toggle: function(id) {
          if (this.has(id)) { this.remove(id); return false; }
          else { this.add(id); return true; }
        },
        addAll: function(newIds) {
          var ids = getIds();
          newIds.forEach(function(id) { if (ids.indexOf(id) === -1) ids.push(id); });
          saveIds(ids);
        },
        clear: function() { localStorage.removeItem(KEY); }
      };
    })();
    </script>
  </head>

  <body>
    <div class="page-bg">

      <!-- Nav -->
      <nav class="nav">
        <div class="nav-inner">
          <div class="nav-links">
            <a href="/en/fontainebleau" class="logo-emoji" aria-label="Boolder">🍷</a>
            <a href="/en/fontainebleau" class="nav-link">Areas</a>
            <a href="/en/fontainebleau/boulders" class="nav-link">Boulders</a>
            <a href="/en/map" class="nav-link">Map</a>
            <a href="/en/projects" class="nav-link">Projects</a>
          </div>
          <div class="nav-search-wrap">
            <button type="button" id="searchOpenBtn" class="nav-search-btn" aria-label="Open search">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
              </svg>
            </button>
          </div>
        </div>
      </nav>

      <!-- Search modal -->
      <div id="searchModal" class="search-modal hidden" role="dialog" aria-modal="true">
        <div class="search-modal-inner">
          <div id="searchBackdrop" class="search-backdrop">
            <div class="search-backdrop-inner"></div>
          </div>
          <div class="search-panel">
            <div class="search-input-wrap">
              <svg class="search-input-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
              </svg>
              <input
                type="text"
                id="searchInput"
                class="search-input"
                placeholder="Search areas and boulders..."
                autocorrect="off"
                autocomplete="off"
                spellcheck="false"
              >
              <button id="searchClearBtn" type="button" class="search-clear-btn hidden" aria-label="Clear">&#10005;</button>
              <button id="searchCancelBtn" type="button" class="search-cancel-btn">Cancel</button>
            </div>
            <ul id="searchResults" class="search-results hidden"></ul>
          </div>
        </div>
      </div>

      <!-- Content -->
      <%= content %>

      <footer class="footer">
        <div class="footer-inner">
          <nav class="footer-nav">
            <div class="footer-nav-item">
              <a href="https://www.boolder.com">Boolder</a>
            </div>
          </nav>
        </div>
      </footer>
    </div>

    <script>
    (function() {
      var modal = document.getElementById('searchModal');
      var input = document.getElementById('searchInput');
      var results = document.getElementById('searchResults');
      var clearBtn = document.getElementById('searchClearBtn');
      var cancelBtn = document.getElementById('searchCancelBtn');
      var backdrop = document.getElementById('searchBackdrop');
      var openBtn = document.getElementById('searchOpenBtn');
      var index = null;
      var activeIdx = -1;

      var colorHex = window.BOOLDER_COLOR_HEX;

      // Lazy-load search index
      function ensureIndex(cb) {
        if (index) return cb();
        fetch('/assets/search-index.json').then(function(r) { return r.json(); }).then(function(data) {
          index = data;
          cb();
        });
      }

      function normalize(str) {
        if (!str) return '';
        return str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-zA-Z0-9]/g, '').toLowerCase();
      }

      function openModal() {
        modal.classList.remove('hidden');
        input.value = '';
        results.classList.add('hidden');
        results.innerHTML = '';
        clearBtn.classList.add('hidden');
        activeIdx = -1;
        input.focus();
        ensureIndex(function() {});
      }

      function closeModal() {
        modal.classList.add('hidden');
        input.value = '';
        results.classList.add('hidden');
        results.innerHTML = '';
        activeIdx = -1;
      }

      function search() {
        var q = normalize(input.value.trim());
        if (!q || !index) {
          results.classList.add('hidden');
          results.innerHTML = '';
          clearBtn.classList.add('hidden');
          activeIdx = -1;
          return;
        }
        clearBtn.classList.remove('hidden');

        // Fuzzy: split query into tokens, all must match
        var tokens = q.match(/[a-z0-9]+/g) || [q];

        var areaHits = index.areas.filter(function(a) {
          return tokens.every(function(t) { return a.n.indexOf(t) !== -1; });
        });

        var problemHits = index.problems.filter(function(p) {
          return tokens.every(function(t) { return p.n.indexOf(t) !== -1; });
        });
        problemHits.sort(function(a, b) { return (b.pop || 0) - (a.pop || 0); });
        problemHits = problemHits.slice(0, 20);

        var items = [];
        areaHits.forEach(function(a) { items.push({type:'area', name:a.name, url:a.url}); });
        problemHits.forEach(function(p) {
          items.push({type:'problem', name:p.name, grade:p.grade, area:p.area, cc:p.cc, cn:p.cn, url:p.url});
        });

        if (items.length === 0) {
          results.classList.add('hidden');
          results.innerHTML = '';
          activeIdx = -1;
          return;
        }

        results.innerHTML = items.map(function(item, i) {
          if (item.type === 'area') {
            return '<li class="search-result" data-url="' + esc(item.url) + '" data-i="' + i + '">' +
              '<span class="search-result-name">' + esc(item.name) + '</span>' +
              '<span class="search-result-label">Area</span>' +
            '</li>';
          }
          var bg = colorHex[item.cc] || 'rgb(80%,80%,80%)';
          var fg = item.cc === 'white' ? '#333' : '#FFF';
          var circle = item.cc
            ? '<span class="badge--circuit-dot-sm" style="background:' + bg + ';color:' + fg + ';">' + (item.cn || '') + '</span>'
            : '';
          return '<li class="search-result" data-url="' + esc(item.url) + '" data-i="' + i + '">' +
            '<div class="search-result-row">' +
              '<div class="search-result-left">' + circle +
                '<span>' + esc(item.name) + '</span>' +
                '<span class="search-result-grade">' + (item.grade || '') + '</span>' +
              '</div>' +
              '<span class="search-result-area">' + esc(item.area) + '</span>' +
            '</div>' +
          '</li>';
        }).join('');

        results.classList.remove('hidden');
        activeIdx = -1;
      }

      function setActive(i) {
        var lis = results.querySelectorAll('li');
        lis.forEach(function(li) { li.style.backgroundColor = ''; });
        activeIdx = i;
        if (activeIdx >= 0 && activeIdx < lis.length) {
          lis[activeIdx].style.backgroundColor = 'var(--accent-bg)';
          lis[activeIdx].scrollIntoView({block:'nearest'});
        }
      }

      function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      // Events
      openBtn.addEventListener('click', openModal);
      backdrop.addEventListener('click', closeModal);
      cancelBtn.addEventListener('click', closeModal);
      clearBtn.addEventListener('click', function() {
        input.value = '';
        input.focus();
        results.classList.add('hidden');
        results.innerHTML = '';
        clearBtn.classList.add('hidden');
        activeIdx = -1;
      });

      input.addEventListener('input', search);

      input.addEventListener('keydown', function(e) {
        var lis = results.querySelectorAll('li');
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          setActive(Math.min(activeIdx + 1, lis.length - 1));
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          setActive(Math.max(activeIdx - 1, 0));
        } else if (e.key === 'Enter' && activeIdx >= 0 && activeIdx < lis.length) {
          e.preventDefault();
          window.location = lis[activeIdx].getAttribute('data-url');
        } else if (e.key === 'Escape') {
          closeModal();
        }
      });

      results.addEventListener('click', function(e) {
        var li = e.target.closest('li');
        if (li && li.getAttribute('data-url')) {
          window.location = li.getAttribute('data-url');
        }
      });

      // Keyboard shortcut: "/" to open search
      document.addEventListener('keydown', function(e) {
        if (e.key === '/' && !modal.classList.contains('hidden') === false && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA' && document.activeElement.tagName !== 'SELECT') {
          e.preventDefault();
          openModal();
        }
      });
    })();
    </script>

  </body>
</html>
