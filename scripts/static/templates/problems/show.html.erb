<%
  topo_html = (defined?(topo_html) && topo_html) || ""
  variants = (defined?(variants) && variants) || []
  area_circuits = (defined?(area_circuits) && area_circuits) || []
  color_hex = { "yellow" => "#FFCC02", "purple" => "#D783FF", "orange" => "#FF9500", "green" => "#77C344", "blue" => "#017AFF", "skyblue" => "#5AC7FA", "salmon" => "#FDAF8A", "red" => "#FF3B2F", "black" => "#000000", "white" => "#FFFFFF" }
  steepness_labels = { "wall" => "Wall", "slab" => "Slab", "overhang" => "Overhang", "roof" => "Roof", "traverse" => "Traverse", "other" => "Other" }
%>

<div class="max-w-7xl mx-auto pt-6 pb-6 sm:px-6 lg:px-8">
  <div class="md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-8">
    <div class="col-span-2">
      <!-- Breadcrumbs -->
      <div class="px-4 sm:px-0">
        <div class="flex items-center space-x-1 text-sm font-medium t-text-sec">
          <div><a href="/en/fontainebleau" class="t-accent-hover">Fontainebleau</a></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          <div><a href="/en/fontainebleau/<%= area["slug"] %>" class="t-accent-hover"><%= area["name"] %></a></div>
        </div>

        <!-- Title + grade -->
        <div class="flex justify-between items-center w-full mt-2">
          <h1 class="text-4xl font-bold"><%= problem["name"] %></h1>
          <div class="t-text-tri text-4xl font-bold"><%= problem["grade"] %></div>
        </div>

        <!-- Metadata badges -->
        <div class="flex flex-wrap items-center gap-2 mt-3">
          <%- if problem["sit_start"] -%>
            <span class="inline-flex items-center rounded-full t-badge px-2.5 py-0.5 text-sm font-medium">Sit start</span>
          <%- end -%>

          <%- if problem["popularity"].to_i > 0 -%>
            <span class="inline-flex items-center gap-1 rounded-full t-badge px-2.5 py-0.5 text-sm">&#9733; <%= problem["popularity"] %></span>
          <%- end -%>

          <%- if problem["steepness"] -%>
            <span class="inline-flex items-center rounded-full t-badge px-2.5 py-0.5 text-sm"><%= steepness_labels[problem["steepness"]] || problem["steepness"] %></span>
          <%- end -%>

          <%- if problem["circuit_color"] -%>
            <%
              c_hex = color_hex[problem["circuit_color"]] || "#999"
              c_text = problem["circuit_color"] == "white" ? "#000" : "#FFF"
            %>
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-sm font-medium" style="background-color: <%= c_hex %>; color: <%= c_text %>;">
              <%= problem["circuit_color"].capitalize %><%= " #{problem["circuit_number"]}" if problem["circuit_number"] %>
            </span>
          <%- end -%>

          <%- if problem["featured"] -%>
            <span class="inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-sm font-medium text-red-400" style="background: var(--surface-hover);">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
              </svg>
              Featured
            </span>
          <%- end -%>
        </div>
      </div>

      <!-- Topo -->
      <div class="mt-4">
        <%- if topo_html.to_s.strip.length > 0 -%>
          <%= topo_html %>
        <%- else -%>
          <div class="w-full aspect-w-4 aspect-h-3 sm:rounded-lg" style="background: var(--surface-hover);">
            <div class="flex flex-wrap justify-center content-center">
              <span class="t-text-tri text-sm">No photo</span>
            </div>
          </div>
        <%- end -%>
      </div>

      <!-- Circuit prev/next navigation -->
      <%- if circuit && (circuit_previous || circuit_next) -%>
        <div class="px-4 sm:px-0 py-2 flex justify-between items-center">
          <div>
            <%- if circuit_previous -%>
              <%
                prev_slug = [circuit_previous["id"], circuit_previous["name"]&.downcase&.gsub(/[^a-z0-9]+/, "-")&.gsub(/-$/, "")].compact.join("-")
                prev_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[circuit_previous["area_id"]]
                prev_area_slug = prev_area ? prev_area["slug"] : area["slug"]
              %>
              <a href="/en/fontainebleau/<%= prev_area_slug %>/<%= prev_slug %>">
                <div class="flex items-center space-x-2 t-accent">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
                  </svg>
                  <div>Previous</div>
                </div>
              </a>
            <%- end -%>
          </div>
          <div>
            <%- if circuit_next -%>
              <%
                next_slug = [circuit_next["id"], circuit_next["name"]&.downcase&.gsub(/[^a-z0-9]+/, "-")&.gsub(/-$/, "")].compact.join("-")
                next_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[circuit_next["area_id"]]
                next_area_slug = next_area ? next_area["slug"] : area["slug"]
              %>
              <a href="/en/fontainebleau/<%= next_area_slug %>/<%= next_slug %>">
                <div class="flex items-center space-x-2 t-accent">
                  <div>Next</div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </a>
            <%- end -%>
          </div>
        </div>
      <%- end -%>

      <!-- Actions -->
      <div class="px-4 sm:px-0 py-2">
        <div data-controller="project-list-button"
          data-project-list-button-problem-id-value="<%= problem["id"] %>"
          data-project-list-button-locale-value="en"
          data-add-label="Add to projects"
          data-added-label="Added to projects">
        </div>

        <a href="/en/map/<%= area["slug"] %>?pid=<%= problem["id"] %>" rel="nofollow">
          <div class="flex items-center space-x-2 t-accent mt-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div>See on map</div>
          </div>
        </a>

        <%- if circuit -%>
          <a href="/en/fontainebleau/circuits/<%= circuit["id"] %>" rel="nofollow">
            <div class="flex items-center space-x-2 t-accent mt-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <div>See circuit</div>
            </div>
          </a>
        <%- end -%>

        <%- if problem["bleau_info_id"].to_s.strip.length > 0 -%>
          <a href="https://bleau.info/a/<%= problem["bleau_info_id"] %>.html" rel="nofollow" target="_blank">
            <div class="flex items-center space-x-2 t-accent mt-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
              <div>See on bleau.info</div>
            </div>
          </a>
        <%- end -%>
      </div>

      <!-- Variants -->
      <%- if variants && variants.any? -%>
        <div class="px-4 sm:px-0 py-4">
          <h2 class="text-xl font-semibold mb-3">Variants</h2>
          <ul>
            <%- variants.each do |variant| -%>
              <%
                v_slug = [variant["id"], variant["name"]&.downcase&.gsub(/[^a-z0-9]+/, "-")&.gsub(/-$/, "")].compact.join("-")
                v_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[variant["area_id"]]
                v_area_slug = v_area ? v_area["slug"] : area["slug"]
              %>
              <li class="mt-2">
                <a href="/en/fontainebleau/<%= v_area_slug %>/<%= v_slug %>">
                  <%- if variant["circuit_color"] && variant["circuit_number"] -%>
                    <%
                      vc_hex = color_hex[variant["circuit_color"]] || "#999"
                      vc_text = variant["circuit_color"] == "white" ? "#000" : "#FFF"
                    %>
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold" style="background-color: <%= vc_hex %>; color: <%= vc_text %>;"><%= variant["circuit_number"] %></span>
                  <%- else -%>
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full t-badge text-xs">&nbsp;</span>
                  <%- end -%>
                  <span class="ml-2 font-medium"><%= variant["name"] %></span>
                  <span class="ml-2 t-text-tri"><%= variant["grade"] %></span>
                </a>
              </li>
            <%- end -%>
          </ul>
        </div>
      <%- end -%>

      <!-- Circuits in this area -->
      <%- if area_circuits && area_circuits.any? -%>
        <div class="px-4 sm:px-0 py-4">
          <h2 class="text-xl font-semibold mb-3">Circuits in <%= area["name"] %></h2>
          <ul role="list">
            <%- area_circuits.each do |ac| -%>
              <%
                ac_hex = color_hex[ac["color"]] || "#999"
                ac_active = circuit && circuit["id"] == ac["id"]
              %>
              <li class="py-1">
                <a href="/en/fontainebleau/circuits/<%= ac["id"] %>" class="flex items-center space-x-2 <%= ac_active ? 'font-semibold' : 't-text-sec t-accent-hover' %>">
                  <span class="inline-block w-3.5 h-3.5 rounded-full flex-shrink-0" style="background-color: <%= ac_hex %>;"></span>
                  <span><%= ac["color"].capitalize %></span>
                  <span class="t-text-tri text-sm"><%= ac["average_grade"] %></span>
                  <%- if ac["beginner_friendly"] -%>
                    <span class="text-emerald-500" title="Beginner friendly">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </span>
                  <%- end -%>
                  <%- if ac["dangerous"] -%>
                    <span class="text-red-500" title="Dangerous">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                      </svg>
                    </span>
                  <%- end -%>
                </a>
              </li>
            <%- end -%>
          </ul>
        </div>
      <%- end -%>

    </div>
  </div>
</div>
