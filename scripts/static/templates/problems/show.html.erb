<%
  # Use self.x to call the TemplateContext method (avoids local variable shadowing)
  _topo_html = self.topo_html.to_s
  _variants = self.variants || []
  _area_circuits = self.area_circuits || []
%>

<div class="container page-section page-section--bottom">
  <div class="">
    <div>
      <!-- Breadcrumbs -->
      <div class="inner">
        <%= Static::ViewHelpers.breadcrumb(["Areas", "/areas"], [area["name"], "/areas/#{area["slug"]}"]) %>

        <!-- Title + grade -->
        <div class="problem-header">
          <h1 class="problem-name"><%= problem["name"] %></h1>
          <div class="problem-grade"><%= problem["grade"] %></div>
        </div>

        <!-- Metadata badges -->
        <div class="problem-badges">
          <%- if problem["sit_start"] -%>
            <span class="badge--sit-start">Sit start</span>
          <%- end -%>

          <%- if problem["popularity"].to_i > 0 -%>
            <span class="badge badge--meta-lg">&#9733; <%= problem["popularity"] %></span>
          <%- end -%>

          <%- if problem["steepness"] -%>
            <span class="badge badge--meta-lg"><%= steepness_labels[problem["steepness"]] || problem["steepness"] %></span>
          <%- end -%>

          <%- if problem["circuit_color"] -%>
            <%= Static::ViewHelpers.circuit_badge(problem["circuit_color"], problem["circuit_number"]) %>
          <%- end -%>

        </div>
      </div>

      <!-- Topo -->
      <div class="topo-section">
        <%- if _topo_html.strip.length > 0 -%>
          <%= _topo_html %>
        <%- else -%>
          <div class="topo-placeholder">
            <span>No photo</span>
          </div>
        <%- end -%>
      </div>

      <!-- Circuit prev/next navigation -->
      <%- if circuit && (circuit_previous || circuit_next) -%>
        <div class="inner circuit-nav">
          <div>
            <%- if circuit_previous -%>
              <%
                prev_slug = Static::ViewHelpers.problem_slug(circuit_previous)
                prev_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[circuit_previous["area_id"]]
                prev_area_slug = prev_area ? prev_area["slug"] : area["slug"]
              %>
              <a href="/areas/<%= prev_area_slug %>/<%= prev_slug %>">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
                </svg>
                <div>Previous</div>
              </a>
            <%- end -%>
          </div>
          <div>
            <%- if circuit_next -%>
              <%
                next_slug = Static::ViewHelpers.problem_slug(circuit_next)
                next_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[circuit_next["area_id"]]
                next_area_slug = next_area ? next_area["slug"] : area["slug"]
              %>
              <a href="/areas/<%= next_area_slug %>/<%= next_slug %>">
                <div>Next</div>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            <%- end -%>
          </div>
        </div>
      <%- end -%>

      <!-- Actions -->
      <div class="inner-section">
        <button type="button" id="projectToggleBtn" class="project-toggle" data-problem-id="<%= problem["id"] %>">
          <svg id="projectIconOutline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
          </svg>
          <svg id="projectIconFilled" xmlns="http://www.w3.org/2000/svg" class="hidden" viewBox="0 0 24 24" fill="currentColor">
            <path fill-rule="evenodd" d="M6.32 2.577a49.255 49.255 0 0111.36 0c1.497.174 2.57 1.46 2.57 2.93V21a.75.75 0 01-1.085.67L12 18.089l-7.165 3.583A.75.75 0 013.75 21V5.507c0-1.47 1.073-2.756 2.57-2.93z" clip-rule="evenodd" />
          </svg>
          <span id="projectToggleLabel">Add to projects</span>
        </button>
        <script>
        (function() {
          var btn = document.getElementById('projectToggleBtn');
          var id = parseInt(btn.getAttribute('data-problem-id'), 10);
          var outline = document.getElementById('projectIconOutline');
          var filled = document.getElementById('projectIconFilled');
          var label = document.getElementById('projectToggleLabel');

          function update(added) {
            outline.classList.toggle('hidden', added);
            filled.classList.toggle('hidden', !added);
            label.textContent = added ? 'Added to projects' : 'Add to projects';
          }

          update(BoolderProjects.has(id));
          btn.addEventListener('click', function() { update(BoolderProjects.toggle(id)); });
        })();
        </script>

        <%= Static::ViewHelpers.action_link("/map/#{area["slug"]}?pid=#{problem["id"]}", Static::ViewHelpers::ICON_MAP_PIN, "See on map", rel: "nofollow") %>

        <%- if circuit -%>
          <%= Static::ViewHelpers.action_link("/areas/circuits/#{circuit["id"]}", Static::ViewHelpers::ICON_CIRCUIT, "See circuit", rel: "nofollow") %>
        <%- end -%>

        <%- if problem["bleau_info_id"].to_s.strip.length > 0 -%>
          <%= Static::ViewHelpers.action_link("https://bleau.info/a/#{problem["bleau_info_id"]}.html", Static::ViewHelpers::ICON_EXTERNAL, "See on bleau.info", rel: "nofollow", target: "_blank") %>
        <%- end -%>
      </div>

      <!-- Variants -->
      <%- if _variants.any? -%>
        <div class="inner-section--lg">
          <h2 class="subsection-title">Variants</h2>
          <ul>
            <%- _variants.each do |variant| -%>
              <%
                v_slug = Static::ViewHelpers.problem_slug(variant)
                v_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[variant["area_id"]]
                v_area_slug = v_area ? v_area["slug"] : area["slug"]
              %>
              <li class="variant-item">
                <a href="/areas/<%= v_area_slug %>/<%= v_slug %>">
                  <%- if variant["circuit_color"] && variant["circuit_number"] -%>
                    <%= Static::ViewHelpers.circuit_badge(variant["circuit_color"], variant["circuit_number"], size: :dot) %>
                  <%- else -%>
                    <span class="badge--empty-dot">&nbsp;</span>
                  <%- end -%>
                  <span class="variant-name"><%= variant["name"] %></span>
                  <span class="variant-grade"><%= variant["grade"] %></span>
                </a>
              </li>
            <%- end -%>
          </ul>
        </div>
      <%- end -%>

      <!-- Circuits in this area -->
      <%- if _area_circuits.any? -%>
        <div class="inner-section--lg">
          <h2 class="subsection-title">Circuits in <%= area["name"] %></h2>
          <ul role="list">
            <%- _area_circuits.each do |ac| -%>
              <%
                ac_hex = Static::ViewHelpers.circuit_hex(ac["color"])
                ac_active = circuit && circuit["id"] == ac["id"]
              %>
              <li class="circuit-sidebar-item">
                <a href="/areas/circuits/<%= ac["id"] %>" class="circuit-sidebar-link<%= ac_active ? ' circuit-sidebar-link--active' : '' %>">
                  <span class="circuit-dot-sm" style="background-color: <%= ac_hex %>;"></span>
                  <span><%= ac["color"].capitalize %></span>
                  <span class="circuit-sidebar-grade"><%= ac["average_grade"] %></span>
                  <%- if ac["beginner_friendly"] -%>
                    <span class="circuit-sidebar-icon circuit-sidebar-icon--beginner" title="Beginner friendly">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </span>
                  <%- end -%>
                  <%- if ac["dangerous"] -%>
                    <span class="circuit-sidebar-icon circuit-sidebar-icon--danger" title="Dangerous">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                      </svg>
                    </span>
                  <%- end -%>
                </a>
              </li>
            <%- end -%>
          </ul>
        </div>
      <%- end -%>

    </div>
  </div>
</div>
