<%
  topo_html = (defined?(topo_html) && topo_html) || ""
  variants = (defined?(variants) && variants) || []
  area_circuits = (defined?(area_circuits) && area_circuits) || []
%>

<div class="max-w-7xl mx-auto pt-6 pb-6 sm:px-6 lg:px-8">
  <div class="md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-8">
    <div class="col-span-2">
      <!-- Breadcrumbs -->
      <div class="px-4 sm:px-0">
        <%= Static::ViewHelpers.breadcrumb(["Fontainebleau", "/en/fontainebleau"], [area["name"], "/en/fontainebleau/#{area["slug"]}"]) %>

        <!-- Title + grade -->
        <div class="flex justify-between items-center w-full mt-2">
          <h1 class="text-4xl font-bold text-gray-900 dark:text-gray-100"><%= problem["name"] %></h1>
          <div class="text-gray-400 dark:text-gray-500 text-4xl font-bold"><%= problem["grade"] %></div>
        </div>

        <!-- Metadata badges -->
        <div class="flex flex-wrap items-center gap-2 mt-3">
          <%- if problem["sit_start"] -%>
            <span class="inline-flex items-center rounded-full bg-amber-100 dark:bg-amber-900/40 text-amber-800 dark:text-amber-200 px-2.5 py-0.5 text-sm font-medium">Sit start</span>
          <%- end -%>

          <%- if problem["popularity"].to_i > 0 -%>
            <span class="inline-flex items-center gap-1 rounded-full bg-gray-200 dark:bg-gray-700 px-2.5 py-0.5 text-sm text-gray-600 dark:text-gray-300">&#9733; <%= problem["popularity"] %></span>
          <%- end -%>

          <%- if problem["steepness"] -%>
            <span class="inline-flex items-center rounded-full bg-gray-200 dark:bg-gray-700 px-2.5 py-0.5 text-sm text-gray-600 dark:text-gray-300"><%= steepness_labels[problem["steepness"]] || problem["steepness"] %></span>
          <%- end -%>

          <%- if problem["circuit_color"] -%>
            <%= Static::ViewHelpers.circuit_badge(problem["circuit_color"], problem["circuit_number"]) %>
          <%- end -%>

          <%- if problem["featured"] -%>
            <span class="inline-flex items-center gap-1 rounded-full bg-red-100 dark:bg-red-900/40 text-red-600 dark:text-red-300 px-2.5 py-0.5 text-sm font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
              </svg>
              Featured
            </span>
          <%- end -%>
        </div>
      </div>

      <!-- Topo -->
      <div class="mt-4">
        <%- if topo_html.to_s.strip.length > 0 -%>
          <%= topo_html %>
        <%- else -%>
          <div class="w-full aspect-w-4 aspect-h-3 bg-gray-300 dark:bg-gray-700 sm:rounded-lg">
            <div class="flex flex-wrap justify-center content-center">
              <span class="text-gray-400 dark:text-gray-500 text-sm">No photo</span>
            </div>
          </div>
        <%- end -%>
      </div>

      <!-- Circuit prev/next navigation -->
      <%- if circuit && (circuit_previous || circuit_next) -%>
        <div class="px-4 sm:px-0 py-2 flex justify-between items-center">
          <div>
            <%- if circuit_previous -%>
              <%
                prev_slug = Static::ViewHelpers.problem_slug(circuit_previous)
                prev_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[circuit_previous["area_id"]]
                prev_area_slug = prev_area ? prev_area["slug"] : area["slug"]
              %>
              <a href="/en/fontainebleau/<%= prev_area_slug %>/<%= prev_slug %>">
                <div class="flex items-center space-x-2 text-emerald-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
                  </svg>
                  <div>Previous</div>
                </div>
              </a>
            <%- end -%>
          </div>
          <div>
            <%- if circuit_next -%>
              <%
                next_slug = Static::ViewHelpers.problem_slug(circuit_next)
                next_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[circuit_next["area_id"]]
                next_area_slug = next_area ? next_area["slug"] : area["slug"]
              %>
              <a href="/en/fontainebleau/<%= next_area_slug %>/<%= next_slug %>">
                <div class="flex items-center space-x-2 text-emerald-600">
                  <div>Next</div>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </div>
              </a>
            <%- end -%>
          </div>
        </div>
      <%- end -%>

      <!-- Actions -->
      <div class="px-4 sm:px-0 py-2">
        <button type="button" id="projectToggleBtn" class="flex items-center space-x-2 text-emerald-600 hover:text-emerald-500" data-problem-id="<%= problem["id"] %>">
          <svg id="projectIconOutline" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
          </svg>
          <svg id="projectIconFilled" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 hidden" viewBox="0 0 24 24" fill="currentColor">
            <path fill-rule="evenodd" d="M6.32 2.577a49.255 49.255 0 0111.36 0c1.497.174 2.57 1.46 2.57 2.93V21a.75.75 0 01-1.085.67L12 18.089l-7.165 3.583A.75.75 0 013.75 21V5.507c0-1.47 1.073-2.756 2.57-2.93z" clip-rule="evenodd" />
          </svg>
          <span id="projectToggleLabel">Add to projects</span>
        </button>
        <script>
        (function() {
          var btn = document.getElementById('projectToggleBtn');
          var id = parseInt(btn.getAttribute('data-problem-id'), 10);
          var outline = document.getElementById('projectIconOutline');
          var filled = document.getElementById('projectIconFilled');
          var label = document.getElementById('projectToggleLabel');

          function update(added) {
            outline.classList.toggle('hidden', added);
            filled.classList.toggle('hidden', !added);
            label.textContent = added ? 'Added to projects' : 'Add to projects';
          }

          update(BoolderProjects.has(id));
          btn.addEventListener('click', function() { update(BoolderProjects.toggle(id)); });
        })();
        </script>

        <%= Static::ViewHelpers.action_link("/en/map/#{area["slug"]}?pid=#{problem["id"]}", Static::ViewHelpers::ICON_MAP_PIN, "See on map", rel: "nofollow") %>

        <%- if circuit -%>
          <%= Static::ViewHelpers.action_link("/en/fontainebleau/circuits/#{circuit["id"]}", Static::ViewHelpers::ICON_CIRCUIT, "See circuit", rel: "nofollow") %>
        <%- end -%>

        <%- if problem["bleau_info_id"].to_s.strip.length > 0 -%>
          <%= Static::ViewHelpers.action_link("https://bleau.info/a/#{problem["bleau_info_id"]}.html", Static::ViewHelpers::ICON_EXTERNAL, "See on bleau.info", rel: "nofollow", target: "_blank") %>
        <%- end -%>
      </div>

      <!-- Variants -->
      <%- if variants && variants.any? -%>
        <div class="px-4 sm:px-0 py-4">
          <h2 class="text-xl font-semibold mb-3">Variants</h2>
          <ul>
            <%- variants.each do |variant| -%>
              <%
                v_slug = Static::ViewHelpers.problem_slug(variant)
                v_area = (defined?(_areas_by_id) && _areas_by_id) && _areas_by_id[variant["area_id"]]
                v_area_slug = v_area ? v_area["slug"] : area["slug"]
              %>
              <li class="mt-2">
                <a href="/en/fontainebleau/<%= v_area_slug %>/<%= v_slug %>">
                  <%- if variant["circuit_color"] && variant["circuit_number"] -%>
                    <%= Static::ViewHelpers.circuit_badge(variant["circuit_color"], variant["circuit_number"], size: :dot) %>
                  <%- else -%>
                    <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-200 dark:bg-gray-700 text-xs">&nbsp;</span>
                  <%- end -%>
                  <span class="ml-2 font-medium"><%= variant["name"] %></span>
                  <span class="ml-2 text-gray-400 dark:text-gray-500"><%= variant["grade"] %></span>
                </a>
              </li>
            <%- end -%>
          </ul>
        </div>
      <%- end -%>

      <!-- Circuits in this area -->
      <%- if area_circuits && area_circuits.any? -%>
        <div class="px-4 sm:px-0 py-4">
          <h2 class="text-xl font-semibold mb-3">Circuits in <%= area["name"] %></h2>
          <ul role="list">
            <%- area_circuits.each do |ac| -%>
              <%
                ac_hex = Static::ViewHelpers.circuit_hex(ac["color"])
                ac_active = circuit && circuit["id"] == ac["id"]
              %>
              <li class="py-1">
                <a href="/en/fontainebleau/circuits/<%= ac["id"] %>" class="flex items-center space-x-2 <%= ac_active ? 'font-semibold text-gray-900 dark:text-gray-100' : 'text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100' %>">
                  <span class="inline-block w-3.5 h-3.5 rounded-full flex-shrink-0" style="background-color: <%= ac_hex %>;"></span>
                  <span><%= ac["color"].capitalize %></span>
                  <span class="text-gray-400 dark:text-gray-500 text-sm"><%= ac["average_grade"] %></span>
                  <%- if ac["beginner_friendly"] -%>
                    <span class="text-emerald-500" title="Beginner friendly">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </span>
                  <%- end -%>
                  <%- if ac["dangerous"] -%>
                    <span class="text-red-500" title="Dangerous">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                      </svg>
                    </span>
                  <%- end -%>
                </a>
              </li>
            <%- end -%>
          </ul>
        </div>
      <%- end -%>

    </div>
  </div>
</div>
