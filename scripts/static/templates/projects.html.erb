<div class="max-w-3xl mx-auto pt-6 pb-12 px-4 sm:px-6 lg:px-8"
  data-controller="project-list"
  data-project-list-locale-value="en">
  <div>
    <h1 class="text-3xl font-bold">My project list</h1>
    <p class="t-text-sec mt-1">Projects are stored locally on your device.</p>
  </div>

  <div class="mt-8 text-center t-text-tri" data-project-list-target="emptyState">
    <p>Your project list is empty. Add problems from their detail pages.</p>
  </div>

  <ul class="mt-6 divide-y" style="border-color: var(--border);" data-project-list-target="problemList">
  </ul>
</div>
