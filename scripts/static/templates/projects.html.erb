<div class="max-w-7xl mx-auto pt-6 pb-6 sm:px-6 lg:px-8">
  <div class="lg:grid lg:grid-cols-2 lg:gap-16">
    <div class="col-span-1">
      <div class="px-4 sm:px-0">
        <h1 class="text-3xl font-bold mb-4"><%= locale == "fr" ? "Ma liste de projets" : "My project list" %></h1>
        <p class="text-gray-500 dark:text-gray-400 text-sm mb-6">
          <%= locale == "fr" ? "Les projets sont stockés localement sur votre appareil." : "Projects are stored locally on your device." %>
        </p>
      </div>
      <div id="project-list-container" class="px-4 sm:px-0">
        <p class="text-gray-400">
          <%= locale == "fr" ? "Aucun problème dans votre liste pour le moment." : "No problems in your project list yet." %>
        </p>
      </div>
    </div>
  </div>
</div>
