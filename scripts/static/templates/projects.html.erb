<div class="container-narrow page-section page-section--bottom">
  <!-- Header: shown when viewing own list -->
  <div id="ownHeader">
    <div class="projects-header">
      <div>
        <h1 class="page-title">Projects</h1>
        <p class="projects-subtitle">Stored locally on your device.</p>
      </div>
      <div class="btn-group">
        <button id="copyNotesBtn" type="button" class="btn btn--outline hidden">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          <span>Copy to notes</span>
        </button>
        <button id="shareBtn" type="button" class="btn btn--primary hidden">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          <span>Share</span>
        </button>
      </div>
    </div>
    <div id="shareNotice" class="notice hidden">
      Link copied to clipboard!
    </div>
  </div>

  <!-- Header: shown when viewing a shared list -->
  <div id="sharedHeader" class="hidden">
    <h1 id="sharedTitle" class="page-title"></h1>
    <p class="projects-subtitle">Shared project list.</p>
    <div class="shared-actions">
      <button id="saveAllBtn" type="button" class="btn btn--primary">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        <span>Save all to my list</span>
      </button>
      <a href="/en/projects" class="btn btn--outline">
        View my list
      </a>
    </div>
    <div id="savedNotice" class="notice hidden">
      Saved to your project list!
    </div>
  </div>

  <!-- Filters (hidden until list has items) -->
  <div id="projectFilters" class="filters-stack hidden">
    <div>
      <label class="filter-label">Grade</label>
      <select id="pf-grade" class="filter-select filter-select--narrow">
        <option value="">All</option>
        <option value="beginner">Beginner (1–3)</option>
        <option value="level4">Level 4</option>
        <option value="level5">Level 5</option>
        <option value="level6">Level 6</option>
        <option value="level7">Level 7</option>
        <option value="level8">Level 8+</option>
      </select>
    </div>
    <div>
      <label class="filter-label">Steepness</label>
      <select id="pf-steepness" class="filter-select filter-select--narrow">
        <option value="">All</option>
        <option value="wall">Wall</option>
        <option value="slab">Slab</option>
        <option value="overhang">Overhang</option>
        <option value="roof">Roof</option>
        <option value="traverse">Traverse</option>
      </select>
    </div>
    <div>
      <label class="filter-label">Area</label>
      <select id="pf-area" class="filter-select filter-select--narrow">
        <option value="">All</option>
      </select>
    </div>
    <div>
      <label class="filter-label">Sort by</label>
      <select id="pf-sort" class="filter-select filter-select--narrow">
        <option value="added">Added order</option>
        <option value="grade">Grade</option>
        <option value="area">Area</option>
      </select>
    </div>
  </div>

  <!-- Empty state -->
  <div id="emptyState" class="empty-state hidden">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
    </svg>
    <p>Your project list is empty.</p>
    <p class="empty-state-cta">
      <a href="/en/fontainebleau" class="btn btn--outline">Explore areas</a>
      <a href="/en/fontainebleau/boulders" class="btn btn--outline">Browse boulders</a>
    </p>
  </div>

  <!-- Problem list -->
  <ul id="problemList" class="project-list"></ul>
</div>

<script>
(function() {
  var colorHex = window.BOOLDER_COLOR_HEX;
  var isShared = false;
  var sharedIds = [];
  var sharedName = '';
  var index = null;

  var allGrades = ["1a","1a+","1b","1b+","1c","1c+","2a","2a+","2b","2b+","2c","2c+","3a","3a+","3b","3b+","3c","3c+","4a","4a+","4b","4b+","4c","4c+","5a","5a+","5b","5b+","5c","5c+","6a","6a+","6b","6b+","6c","6c+","7a","7a+","7b","7b+","7c","7c+","8a","8a+","8b","8b+","8c","8c+","9a","9a+","9b","9b+","9c","9c+"];
  var gradeRanges = {
    beginner: new Set(allGrades.slice(0, 18)),
    level4: new Set(allGrades.slice(18, 24)),
    level5: new Set(allGrades.slice(24, 30)),
    level6: new Set(allGrades.slice(30, 36)),
    level7: new Set(allGrades.slice(36, 42)),
    level8: new Set(allGrades.slice(42)),
  };

  var filtersEl = document.getElementById('projectFilters');
  var gradeEl = document.getElementById('pf-grade');
  var steepnessEl = document.getElementById('pf-steepness');
  var areaEl = document.getElementById('pf-area');
  var sortEl = document.getElementById('pf-sort');

  function parseFragment() {
    var hash = window.location.hash.slice(1);
    if (!hash) return;
    var params = {};
    hash.split('&').forEach(function(part) {
      var kv = part.split('=');
      if (kv.length === 2) params[kv[0]] = decodeURIComponent(kv[1]);
    });
    if (params.p) {
      isShared = true;
      sharedIds = params.p.split(',').map(Number).filter(Boolean);
      sharedName = params.n || 'Shared projects';
    }
  }

  function ensureIndex(cb) {
    if (index) return cb();
    fetch('/assets/search-index.json').then(function(r) { return r.json(); }).then(function(data) {
      index = {};
      data.problems.forEach(function(p) { index[p.id] = p; });
      cb();
    });
  }

  function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  function gradeIndex(g) { return allGrades.indexOf(g); }

  // Populate area dropdown from the problems in the user's list
  function populateAreaFilter(ids) {
    var areas = {};
    ids.forEach(function(id) {
      var p = index[id];
      if (p && p.area) areas[p.area] = 1;
    });
    areaEl.innerHTML = '<option value="">All</option>';
    Object.keys(areas).sort().forEach(function(name) {
      var opt = document.createElement('option');
      opt.value = name;
      opt.textContent = name;
      areaEl.appendChild(opt);
    });
  }

  function filterAndSort(ids) {
    var gradeFilter = gradeEl.value;
    var steepnessFilter = steepnessEl.value;
    var areaFilter = areaEl.value;
    var sortBy = sortEl.value;

    var problems = ids.map(function(id) { return index[id]; }).filter(Boolean);

    if (gradeFilter && gradeRanges[gradeFilter]) {
      var allowed = gradeRanges[gradeFilter];
      problems = problems.filter(function(p) { return allowed.has(p.grade); });
    }
    if (steepnessFilter) {
      problems = problems.filter(function(p) { return p.st === steepnessFilter; });
    }
    if (areaFilter) {
      problems = problems.filter(function(p) { return p.area === areaFilter; });
    }

    if (sortBy === 'grade') {
      problems.sort(function(a, b) { return gradeIndex(a.grade) - gradeIndex(b.grade); });
    } else if (sortBy === 'area') {
      problems.sort(function(a, b) { return (a.area || '').localeCompare(b.area || ''); });
    }
    // 'added' keeps the original order

    return problems;
  }

  function renderList(ids, editable) {
    var list = document.getElementById('problemList');
    var empty = document.getElementById('emptyState');

    if (ids.length === 0) {
      list.innerHTML = '';
      empty.classList.remove('hidden');
      filtersEl.classList.add('hidden');
      return;
    }
    empty.classList.add('hidden');
    if (editable) filtersEl.classList.remove('hidden');

    populateAreaFilter(ids);
    var problems = filterAndSort(ids);

    list.innerHTML = problems.map(function(p) {
      var circle = '';
      if (p.cc) {
        var bg = colorHex[p.cc] || '#999';
        var fg = p.cc === 'white' ? '#333' : '#FFF';
        circle = '<span class="badge--circuit-dot-sm" style="background:' + bg + ';color:' + fg + ';">' + (p.cn || '') + '</span>';
      }

      var removeBtn = editable
        ? '<button type="button" class="remove-btn" data-id="' + p.id + '" title="Remove">' +
          '<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>' +
          '</button>'
        : '';

      return '<li class="project-item">' +
        '<a href="' + esc(p.url) + '" class="project-item-link">' +
          circle +
          '<span class="project-item-name">' + esc(p.name) + '</span>' +
          '<span class="project-item-grade">' + esc(p.grade) + '</span>' +
          '<span class="project-item-area">' + esc(p.area) + '</span>' +
        '</a>' +
        removeBtn +
      '</li>';
    }).join('');

    if (editable) {
      list.querySelectorAll('.remove-btn').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
          e.preventDefault();
          var removeId = parseInt(btn.getAttribute('data-id'), 10);
          BoolderProjects.remove(removeId);
          renderList(BoolderProjects.list(), true);
          updateShareBtn();
        });
      });
    }
  }

  function updateShareBtn() {
    var ids = BoolderProjects.list();
    var show = ids.length > 0;
    ['shareBtn', 'copyNotesBtn'].forEach(function(id) {
      var el = document.getElementById(id);
      if (show) el.classList.remove('hidden');
      else el.classList.add('hidden');
    });
  }

  function buildShareUrl(ids) {
    var base = window.location.origin + '/en/projects';
    return base + '#n=Projects&p=' + ids.join(',');
  }

  parseFragment();

  // Re-render when filters change (without removing items from the list)
  [gradeEl, steepnessEl, areaEl, sortEl].forEach(function(el) {
    el.addEventListener('change', function() {
      var ids = isShared ? sharedIds : BoolderProjects.list();
      renderList(ids, !isShared);
    });
  });

  if (isShared) {
    document.getElementById('ownHeader').classList.add('hidden');
    document.getElementById('sharedHeader').classList.remove('hidden');
    document.getElementById('sharedTitle').textContent = sharedName;

    ensureIndex(function() { renderList(sharedIds, false); });

    document.getElementById('saveAllBtn').addEventListener('click', function() {
      BoolderProjects.addAll(sharedIds);
      document.getElementById('savedNotice').classList.remove('hidden');
    });
  } else {
    ensureIndex(function() {
      renderList(BoolderProjects.list(), true);
      updateShareBtn();
    });

    document.getElementById('shareBtn').addEventListener('click', function() {
      var ids = BoolderProjects.list();
      var url = buildShareUrl(ids);
      if (navigator.clipboard) {
        navigator.clipboard.writeText(url);
      }
      document.getElementById('shareNotice').classList.remove('hidden');
      setTimeout(function() { document.getElementById('shareNotice').classList.add('hidden'); }, 3000);
    });

    document.getElementById('copyNotesBtn').addEventListener('click', function() {
      var ids = BoolderProjects.list();
      var origin = window.location.origin;
      var items = ids.map(function(id) {
        var p = index[id];
        if (!p) return '';
        return '<li><input type="checkbox">' +
          '<a href="' + origin + esc(p.url) + '">' + esc(p.name) + '</a> ' +
          esc(p.grade) + ' — ' + esc(p.area) + '</li>';
      }).filter(Boolean);
      var html = '<b>Projects</b><ul>' + items.join('') + '</ul>';
      var plain = 'Projects\n' + ids.map(function(id) {
        var p = index[id];
        if (!p) return '';
        return p.name + ' ' + p.grade + ' — ' + p.area + ' (' + origin + p.url + ')';
      }).filter(Boolean).join('\n');

      navigator.clipboard.write([
        new ClipboardItem({
          'text/html': new Blob([html], { type: 'text/html' }),
          'text/plain': new Blob([plain], { type: 'text/plain' })
        })
      ]);
      document.getElementById('shareNotice').textContent = 'Copied to clipboard!';
      document.getElementById('shareNotice').classList.remove('hidden');
      setTimeout(function() {
        document.getElementById('shareNotice').classList.add('hidden');
        document.getElementById('shareNotice').textContent = 'Link copied to clipboard!';
      }, 3000);
    });
  }
})();
</script>
