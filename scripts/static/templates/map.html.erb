<!DOCTYPE html>
<html lang="en" class="map-page">
  <head>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= page_title %> — Boolder</title>

    <link rel="stylesheet" href="/assets/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.css" rel="stylesheet">
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.js"></script>
    <script>
    window.BOOLDER_COLOR_HEX = <%= Static::ViewHelpers.color_hex_json %>;
    var BoolderProjects = { list: function() { try { return JSON.parse(localStorage.getItem('boolder_projects')) || []; } catch(e) { return []; } } };
    window.updateNavProjectCount = function() {
      var el = document.getElementById('nav-project-count');
      if (!el) return;
      var n = BoolderProjects.list().length;
      if (n > 0) { el.textContent = n; el.classList.remove('hidden'); }
      else { el.classList.add('hidden'); }
    };
    // Weather indicator
    (function() {
      var WMO_ICON = {0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',53:'🌦',55:'🌧',61:'🌧',63:'🌧',65:'🌧',71:'🌨',73:'🌨',75:'🌨',80:'🌦',81:'🌧',82:'🌧',95:'⛈',96:'⛈',99:'⛈'};
      fetch('https://api.open-meteo.com/v1/forecast?latitude=48.4036&longitude=2.5843&daily=weather_code,temperature_2m_max&timezone=Europe%2FParis&forecast_days=1')
        .then(function(r){return r.json();}).then(function(data){
          var d=data.daily; if(!d||!d.time)return;
          var el=document.getElementById('nav-weather');
          if(el){el.textContent=(WMO_ICON[d.weather_code[0]]||'❓')+' '+Math.round(d.temperature_2m_max[0])+'°';el.classList.remove('hidden');}
        }).catch(function(){});
    })();
    </script>
  </head>

  <body class="map-page">
    <div class="map-layout">
      <div class="map-layout-nav">
        <nav class="nav">
          <div class="nav-inner">
            <button type="button" id="menuToggleBtn" class="nav-menu-btn">
              <span class="logo-emoji">🍷</span><span>Menu</span>
            </button>
            <div class="nav-right">
              <a href="/weather" id="nav-weather" class="nav-weather hidden" aria-label="Weather forecast"></a>
              <button type="button" id="searchOpenBtn" class="nav-search-btn" aria-label="Open search">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd" />
                </svg>
              </button>
            </div>
          </div>
        </nav>

        <!-- Menu modal -->
        <div id="navOverlay" class="nav-overlay hidden"></div>
        <div id="navMenu" class="nav-dropdown hidden">
          <div class="nav-dropdown-header">
            <button type="button" id="menuCloseBtn" class="nav-menu-btn">
              <span class="logo-emoji">🍷</span><span>Close</span>
            </button>
          </div>
          <a href="/projects" class="nav-dropdown-link">Projects<span id="nav-project-count" class="nav-count hidden"></span></a>
          <a href="/areas" class="nav-dropdown-link">Areas</a>
          <a href="/areas/boulders" class="nav-dropdown-link">Boulders</a>
          <a href="/map" class="nav-dropdown-link">Map</a>
        </div>
      </div>

      <!-- Map container -->
      <div class="map-viewport" id="map-container">
        <div id="map"></div>

        <!-- Match count pill (shown when filters are active) -->
        <div id="matchCount" class="match-count hidden">
          <span></span>
        </div>

        <!-- Bottom buttons -->
        <div class="map-controls">
          <button id="filterBtn" type="button" class="map-btn">
            <span id="filterCounter" class="filter-counter hidden">1</span>
            <svg id="filterIcon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
            <span>Filters</span>
          </button>
          <button id="findClosestBtn" type="button" class="map-btn">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
            <span>Find closest</span>
          </button>
        </div>

        <!-- Filters modal -->
        <div id="filterModal" class="filter-modal hidden" role="dialog">
          <div class="modal-backdrop"></div>
          <div class="modal-container">
            <div class="modal-center">
              <div class="modal-panel">
                <div class="modal-close">
                  <button id="filterCloseBtn" type="button">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                  </button>
                </div>
                <div class="modal-filters">
                  <!-- Grade filter -->
                  <div>
                    <label class="filter-label">Grade</label>
                    <select id="filter-grade" class="filter-select">
                      <option value="">All</option>
                      <option value="beginner">Beginner (1a &rarr; 3c+)</option>
                      <option value="level4">Level 4</option>
                      <option value="level5">Level 5</option>
                      <option value="level6">Level 6</option>
                      <option value="level7">Level 7</option>
                      <option value="custom">Custom</option>
                    </select>
                    <div id="customGradePicker" class="grade-picker hidden">
                      <div>
                        <label for="gradeMin" class="filter-label">Min</label>
                        <select id="gradeMin" class="filter-select">
                          <% %w[1a 1b 1c 2a 2b 2c 3a 3b 3c 4a 4b 4c 5a 5b 5c 6a 6b 6c 7a 7b 7c 8a 8b 8c 9a].each do |g| %>
                            <option<%= g == "4a" ? " selected" : "" %>><%= g %></option>
                          <% end %>
                        </select>
                      </div>
                      <div>
                        <label for="gradeMax" class="filter-label">Max</label>
                        <select id="gradeMax" class="filter-select">
                          <% %w[1a 1b 1c 2a 2b 2c 3a 3b 3c 4a 4b 4c 5a 5b 5c 6a 6b 6c 7a 7b 7c 8a 8b 8c 9a].each do |g| %>
                            <option<%= g == "5a" ? " selected" : "" %>><%= g %></option>
                          <% end %>
                        </select>
                      </div>
                    </div>
                  </div>

                  <!-- Steepness filter -->
                  <div>
                    <label class="filter-label">Steepness</label>
                    <select id="filter-steepness" class="filter-select">
                      <option value="">All</option>
                      <option value="wall">Wall</option>
                      <option value="slab">Slab</option>
                      <option value="overhang">Overhang</option>
                      <option value="roof">Roof</option>
                      <option value="traverse">Traverse</option>
                    </select>
                  </div>

                  <!-- Circuit filter -->
                  <div>
                    <label class="filter-label">Circuit</label>
                    <select id="filter-circuit" class="filter-select">
                      <option value="">All</option>
                    </select>
                  </div>

                  <!-- Area tag filter -->
                  <div>
                    <label class="filter-label">Filter area by</label>
                    <select id="filter-area-tag" class="filter-select">
                      <option value="">All</option>
                      <option value="beginner_friendly">Beginner friendly</option>
                      <option value="family_friendly">Family friendly</option>
                      <option value="dry_fast">Dries fast</option>
                    </select>
                  </div>
                </div>
                <div class="modal-actions">
                  <button id="applyFiltersBtn" type="button" class="btn btn--primary">Apply filters</button>
                  <button id="clearFiltersBtn" type="button" class="btn btn--outline">Clear filters</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Search modal -->
    <div id="searchModal" class="search-modal hidden" role="dialog" aria-modal="true">
      <div class="search-modal-inner">
        <div id="searchBackdrop" class="search-backdrop">
          <div class="search-backdrop-inner"></div>
        </div>
        <div class="search-panel">
          <div class="search-input-wrap">
            <svg class="search-input-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
            </svg>
            <input type="text" id="searchInput" class="search-input" placeholder="Search areas and boulders..." autocorrect="off" autocomplete="off" spellcheck="false">
            <button id="searchClearBtn" type="button" class="search-clear-btn hidden" aria-label="Clear">&#10005;</button>
            <button id="searchCancelBtn" type="button" class="search-cancel-btn">Cancel</button>
          </div>
          <ul id="searchResults" class="search-results hidden"></ul>
        </div>
      </div>
    </div>

    <script>
      (function() {
        const mapData = <%= map_data_json %>;
        const boundsData = <%= bounds_json %>;
        const problemData = <%= problem_json %>;
        const allCircuits = <%= circuits_json %>;

        const allGrades = ["1a","1a+","1b","1b+","1c","1c+","2a","2a+","2b","2b+","2c","2c+","3a","3a+","3b","3b+","3c","3c+","4a","4a+","4b","4b+","4c","4c+","5a","5a+","5b","5b+","5c","5c+","6a","6a+","6b","6b+","6c","6c+","7a","7a+","7b","7b+","7c","7c+","8a","8a+","8b","8b+","8c","8c+","9a","9a+","9b","9b+","9c","9c+"];

        mapboxgl.accessToken = '<%= mapbox_token %>';

        const map = new mapboxgl.Map({
          container: 'map',
          hash: true,
          style: 'mapbox://styles/nmondollot/cl95n147u003k15qry7pvfmq2',
          bounds: [[2.4806787, 48.2868427],[2.7698927, 48.473906]],
          padding: 5,
        });

        map.addControl(new mapboxgl.ScaleControl({ maxWidth: 100, unit: 'metric' }));
        if (!('ontouchstart' in window)) {
          map.addControl(new mapboxgl.NavigationControl());
        }
        map.addControl(new mapboxgl.GeolocateControl({
          positionOptions: { enableHighAccuracy: true },
          trackUserLocation: true,
          showUserHeading: true
        }));

        let pendingPopup = null;
        map.on('moveend', () => {
          if (pendingPopup) { pendingPopup.addTo(map); pendingPopup = null; }
        });

        map.on('load', () => {
          map.addSource('problems', {
            type: 'vector',
            url: 'mapbox://nmondollot.4xsv235p',
            promoteId: 'id'
          });

          map.addLayer({
            id: 'problems',
            type: 'circle',
            source: 'problems',
            'source-layer': 'problems-ayes3a',
            minzoom: 15,
            layout: {
              visibility: 'visible',
              'circle-sort-key': ["case", ["has", "circuitId"], 2, 1]
            },
            paint: {
              'circle-radius': ["interpolate", ["linear"], ["zoom"], 15, 2, 18, 4, 22, ["case", ["has", "circuitNumber"], 16, 10]],
              'circle-color': [
                "match", ["get", "circuitColor"],
                "yellow", "#FFCC02", "purple", "#D783FF", "orange", "#FF9500",
                "green", "#77C344", "blue", "#017AFF", "skyblue", "#5AC7FA",
                "salmon", "#FDAF8A", "red", "#FF3B2F", "black", "#000000",
                "white", "#FFFFFF", "#878A8D"
              ],
              'circle-opacity': ["interpolate", ["linear"], ["zoom"], 14.5, 0, 15, 1]
            },
            filter: ["match", ["geometry-type"], ["Point"], true, false],
          }, "areas");

          map.addLayer({
            id: 'problems-texts',
            type: 'symbol',
            source: 'problems',
            'source-layer': 'problems-ayes3a',
            minzoom: 19,
            layout: {
              visibility: 'visible',
              'text-allow-overlap': true,
              'text-field': ["to-string", ["get", "circuitNumber"]],
              'text-size': ["interpolate", ["linear"], ["zoom"], 19, 10, 22, 20],
            },
            paint: {
              'text-color': ["case", ["match", ["get", "circuitColor"], ["", "white"], true, false], "#333", "#fff"]
            },
            filter: ["match", ["geometry-type"], ["Point"], true, false],
          });

          // Improve area layer contrast against the map background
          map.setPaintProperty('areas', 'text-color', '#1a1a1a');
          map.setPaintProperty('areas', 'text-halo-color', '#ffffff');
          map.setPaintProperty('areas', 'text-halo-width', 1.5);
          map.setPaintProperty('areas-hulls', 'fill-opacity', 0.3);

          if (boundsData) {
            const cam = map.cameraForBounds(
              [[boundsData.southWest.lng, boundsData.southWest.lat], [boundsData.northEast.lng, boundsData.northEast.lat]],
              { padding: { top: 20, bottom: 100, left: 20, right: 20 } }
            );
            cam.zoom = Math.max(15, cam.zoom);
            cam.speed = 2;
            map.flyTo(cam);
          }

          if (problemData) {
            map.flyTo({ center: [problemData.lng, problemData.lat], zoom: 20, speed: 2 });
            const info = mapData.problemLookup[problemData.id];
            if (info) {
              pendingPopup = new mapboxgl.Popup({ closeButton: false, focusAfterOpen: false, offset: [0, -8] })
                .setLngLat([problemData.lng, problemData.lat])
                .setHTML('<a href="' + info.url + '">' + (info.name || '') + '</a><span class="map-popup-grade">' + (info.grade || '') + '</span>');
            }
          }
        });

        map.on('mouseenter', 'problems', () => { map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', 'problems', () => { map.getCanvas().style.cursor = ''; });

        map.on('click', 'problems', (e) => {
          const props = e.features[0].properties;
          const coords = e.features[0].geometry.coordinates.slice();
          const info = mapData.problemLookup[props.id];

          let html;
          if (info) {
            html = '<a href="' + info.url + '">' + (info.name || '') + '</a><span class="map-popup-grade">' + (info.grade || '') + '</span>';
          } else {
            html = (props.name || '') + '<span class="map-popup-grade">' + (props.grade || '') + '</span>';
          }

          new mapboxgl.Popup({ closeButton: false, focusAfterOpen: false, offset: [0, -8] })
            .setLngLat(coords)
            .setHTML(html)
            .addTo(map);
        });

        function flyToBounds(bounds) {
          const cam = map.cameraForBounds(bounds, { padding: { top: 20, bottom: 100, left: 20, right: 20 } });
          cam.zoom = Math.max(15, cam.zoom);
          cam.speed = 2;
          map.flyTo(cam);
        }

        ['areas', 'areas-hulls'].forEach(layer => {
          map.on('mouseenter', layer, () => { if (map.getZoom() < 15) map.getCanvas().style.cursor = 'pointer'; });
          map.on('mouseleave', layer, () => { if (map.getZoom() < 15) map.getCanvas().style.cursor = ''; });
          map.on('click', layer, (e) => {
            if (map.getZoom() < 15) {
              const p = e.features[0].properties;
              flyToBounds([[p.southWestLon, p.southWestLat], [p.northEastLon, p.northEastLat]]);
            }
          });
        });

        map.on('mouseenter', 'pois', () => { if (map.getZoom() >= 12) map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', 'pois', () => { if (map.getZoom() >= 12) map.getCanvas().style.cursor = ''; });
        map.on('click', 'pois', (e) => {
          if (map.getZoom() >= 12) {
            const coords = e.features[0].geometry.coordinates.slice();
            new mapboxgl.Popup({ closeButton: false, focusAfterOpen: false, offset: [0, -8] })
              .setLngLat(coords)
              .setHTML('<a href="' + e.features[0].properties.googleUrl + '" target="_blank">See on Google</a>')
              .addTo(map);
          }
        });

        map.on('mouseenter', 'clusters', () => { if (map.getZoom() <= 12) map.getCanvas().style.cursor = 'pointer'; });
        map.on('mouseleave', 'clusters', () => { if (map.getZoom() <= 12) map.getCanvas().style.cursor = ''; });
        map.on('click', 'clusters', (e) => {
          if (map.getZoom() <= 12) {
            const p = e.features[0].properties;
            flyToBounds([[p.southWestLon, p.southWestLat], [p.northEastLon, p.northEastLat]]);
          }
        });

        // --- Filters ---
        const filterModal = document.getElementById('filterModal');
        const filterBtn = document.getElementById('filterBtn');
        const filterCounter = document.getElementById('filterCounter');
        const filterIconEl = document.getElementById('filterIcon');
        const gradeEl = document.getElementById('filter-grade');
        const customPicker = document.getElementById('customGradePicker');
        const steepnessEl = document.getElementById('filter-steepness');
        const circuitEl = document.getElementById('filter-circuit');
        const areaTagEl = document.getElementById('filter-area-tag');

        function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }
        allCircuits.forEach(c => {
          const opt = document.createElement('option');
          opt.value = c.id;
          opt.textContent = c.area_name + ' \u2013 ' + capitalize(c.color);
          circuitEl.appendChild(opt);
        });

        filterBtn.addEventListener('click', () => filterModal.classList.remove('hidden'));
        document.getElementById('filterCloseBtn').addEventListener('click', () => filterModal.classList.add('hidden'));
        document.querySelector('.modal-container').addEventListener('click', (e) => {
          // Close when clicking outside the panel (on the backdrop area)
          if (!e.target.closest('.modal-panel')) filterModal.classList.add('hidden');
        });

        gradeEl.addEventListener('change', () => {
          customPicker.classList.toggle('hidden', gradeEl.value !== 'custom');
        });

        // Returns the set of area IDs matching the selected tag, or null if no tag selected
        function getSelectedAreaIds() {
          if (!areaTagEl.value) return null;
          return new Set(mapData.tagAreaIds[areaTagEl.value] || []);
        }

        // Build Mapbox filter expression for the problems layer
        function buildFilter() {
          const conditions = [];
          let grades;
          const gradeRanges = {
            beginner: allGrades.slice(0, 18),
            level4: allGrades.slice(18, 24),
            level5: allGrades.slice(24, 30),
            level6: allGrades.slice(30, 36),
            level7: allGrades.slice(36, 42),
            level8: allGrades.slice(42, 48),
          };

          if (gradeEl.value === 'custom') {
            const min = document.getElementById('gradeMin').value;
            const max = document.getElementById('gradeMax').value;
            grades = allGrades.slice(allGrades.indexOf(min), allGrades.indexOf(max) + 2);
          } else {
            grades = gradeRanges[gradeEl.value] || null;
          }
          if (grades) conditions.push(['match', ['get', 'grade'], grades, true, false]);

          if (steepnessEl.value) conditions.push(['==', ['get', 'steepness'], steepnessEl.value]);
          if (circuitEl.value) conditions.push(['==', ['get', 'circuitId'], parseInt(circuitEl.value)]);

          // Filter problems by area: collect matching problem IDs from the lookup
          const areaIds = getSelectedAreaIds();
          if (areaIds) {
            const matchingIds = [];
            for (const id in mapData.problemLookup) {
              if (areaIds.has(mapData.problemLookup[id].areaId)) matchingIds.push(parseInt(id));
            }
            conditions.push(['match', ['get', 'id'], matchingIds.length > 0 ? matchingIds : [0], true, false]);
          }

          if (conditions.length === 0) return null;
          if (conditions.length === 1) return conditions[0];
          return ['all'].concat(conditions);
        }

        // Build Mapbox filter expression for the areas/areas-hulls layers
        function buildAreaFilter() {
          const areaIds = getSelectedAreaIds();
          if (!areaIds) return null;
          const ids = Array.from(areaIds);
          return ['match', ['get', 'areaId'], ids.length > 0 ? ids : [0], true, false];
        }

        function countActiveFilters() {
          let n = 0;
          if (gradeEl.value) n++;
          if (steepnessEl.value) n++;
          if (circuitEl.value) n++;
          if (areaTagEl.value) n++;
          return n;
        }

        function matchesFilters(p, gradeSet, steepness, circuitId, areaIds) {
          if (gradeSet && !gradeSet.has(p.grade)) return false;
          if (steepness && p.steepness !== steepness) return false;
          if (circuitId && p.circuitId !== circuitId) return false;
          if (areaIds && !areaIds.has(p.areaId)) return false;
          return true;
        }

        function currentFilterCriteria() {
          const gradeRanges = {
            beginner: allGrades.slice(0, 18),
            level4: allGrades.slice(18, 24),
            level5: allGrades.slice(24, 30),
            level6: allGrades.slice(30, 36),
            level7: allGrades.slice(36, 42),
            level8: allGrades.slice(42, 48),
          };
          let gradeSet = null;
          if (gradeEl.value === 'custom') {
            const min = document.getElementById('gradeMin').value;
            const max = document.getElementById('gradeMax').value;
            gradeSet = new Set(allGrades.slice(allGrades.indexOf(min), allGrades.indexOf(max) + 2));
          } else if (gradeEl.value && gradeRanges[gradeEl.value]) {
            gradeSet = new Set(gradeRanges[gradeEl.value]);
          }
          return {
            gradeSet: gradeSet,
            steepness: steepnessEl.value || null,
            circuitId: circuitEl.value ? parseInt(circuitEl.value) : null,
            areaIds: getSelectedAreaIds()
          };
        }

        function countAndBound(criteria) {
          let minLat = 90, maxLat = -90, minLng = 180, maxLng = -180;
          let count = 0;
          for (const id in mapData.problemLookup) {
            const p = mapData.problemLookup[id];
            if (!p.lat || !p.lng) continue;
            if (!matchesFilters(p, criteria.gradeSet, criteria.steepness, criteria.circuitId, criteria.areaIds)) continue;
            if (p.lat < minLat) minLat = p.lat;
            if (p.lat > maxLat) maxLat = p.lat;
            if (p.lng < minLng) minLng = p.lng;
            if (p.lng > maxLng) maxLng = p.lng;
            count++;
          }
          return { count, bounds: count > 0 ? [[minLng, minLat], [maxLng, maxLat]] : null };
        }

        const matchCountEl = document.getElementById('matchCount');

        function applyAllFilters() {
          const filter = buildFilter();
          const n = countActiveFilters();

          if (n > 0) {
            filterCounter.textContent = n;
            filterCounter.classList.remove('hidden');
            filterIconEl.classList.add('hidden');
          } else {
            filterCounter.classList.add('hidden');
            filterIconEl.classList.remove('hidden');
          }

          const baseFilter = ['match', ['geometry-type'], ['Point'], true, false];
          ['problems', 'problems-texts'].forEach(layer => {
            map.setFilter(layer, filter ? ['all', baseFilter, filter] : baseFilter);
          });

          // Filter area labels and hulls when an area tag is selected
          const areaFilter = buildAreaFilter();
          ['areas', 'areas-hulls'].forEach(layer => {
            map.setFilter(layer, areaFilter);
          });

          if (n > 0) {
            const result = countAndBound(currentFilterCriteria());
            matchCountEl.querySelector('span').textContent = result.count.toLocaleString() + ' boulders';
            matchCountEl.classList.remove('hidden');
            if (result.bounds) {
              map.fitBounds(result.bounds, {
                padding: { top: 40, bottom: 100, left: 40, right: 40 },
                maxZoom: 18,
                speed: 2
              });
            }
          } else {
            matchCountEl.classList.add('hidden');
          }
        }

        document.getElementById('applyFiltersBtn').addEventListener('click', () => {
          filterModal.classList.add('hidden');
          applyAllFilters();
        });

        document.getElementById('clearFiltersBtn').addEventListener('click', () => {
          filterModal.classList.add('hidden');
          gradeEl.value = '';
          customPicker.classList.add('hidden');
          steepnessEl.value = '';
          circuitEl.value = '';
          areaTagEl.value = '';
          applyAllFilters();
        });

        gradeEl.value = '';
        steepnessEl.value = '';
        circuitEl.value = '';
        areaTagEl.value = '';

        document.getElementById('gradeMin').addEventListener('change', () => {
          const iMin = allGrades.indexOf(document.getElementById('gradeMin').value);
          const iMax = allGrades.indexOf(document.getElementById('gradeMax').value);
          document.getElementById('gradeMax').value = allGrades[Math.max(iMin, iMax)];
        });
        document.getElementById('gradeMax').addEventListener('change', () => {
          const iMin = allGrades.indexOf(document.getElementById('gradeMin').value);
          const iMax = allGrades.indexOf(document.getElementById('gradeMax').value);
          document.getElementById('gradeMin').value = allGrades[Math.min(iMin, iMax)];
        });

        // --- Find closest ---
        document.getElementById('findClosestBtn').addEventListener('click', () => {
          const btn = document.getElementById('findClosestBtn');
          btn.disabled = true;
          btn.querySelector('span').textContent = 'Locating\u2026';

          navigator.geolocation.getCurrentPosition(pos => {
            const userLng = pos.coords.longitude;
            const userLat = pos.coords.latitude;
            const { gradeSet, steepness, circuitId, areaIds } = currentFilterCriteria();

            let bestDist = Infinity, bestId = null;
            for (const id in mapData.problemLookup) {
              const p = mapData.problemLookup[id];
              if (!p.lat || !p.lng) continue;
              if (!matchesFilters(p, gradeSet, steepness, circuitId, areaIds)) continue;
              const d = (p.lng - userLng) ** 2 + (p.lat - userLat) ** 2;
              if (d < bestDist) { bestDist = d; bestId = id; }
            }

            btn.disabled = false;
            btn.querySelector('span').textContent = 'Find closest';

            if (bestId !== null) {
              const p = mapData.problemLookup[bestId];
              map.flyTo({ center: [p.lng, p.lat], zoom: 20, speed: 2 });
              pendingPopup = new mapboxgl.Popup({ closeButton: false, focusAfterOpen: false, offset: [0, -8] })
                .setLngLat([p.lng, p.lat])
                .setHTML('<a href="' + p.url + '">' + (p.name || '') + '</a><span class="map-popup-grade">' + (p.grade || '') + '</span>');
            }
          }, () => {
            btn.disabled = false;
            btn.querySelector('span').textContent = 'Find closest';
          });
        });

        map.on('movestart', () => {
          history.replaceState({}, '', '/map');
        });
      })();
    </script>
    <script>
    updateNavProjectCount();
    (function() {
      var menu = document.getElementById('navMenu');
      var overlay = document.getElementById('navOverlay');
      function openMenu() { menu.classList.remove('hidden'); overlay.classList.remove('hidden'); }
      function closeMenu() { menu.classList.add('hidden'); overlay.classList.add('hidden'); }
      document.getElementById('menuToggleBtn').addEventListener('click', openMenu);
      document.getElementById('menuCloseBtn').addEventListener('click', closeMenu);
      overlay.addEventListener('click', closeMenu);
    })();

    // Search
    (function() {
      var modal = document.getElementById('searchModal');
      var input = document.getElementById('searchInput');
      var results = document.getElementById('searchResults');
      var clearBtn = document.getElementById('searchClearBtn');
      var cancelBtn = document.getElementById('searchCancelBtn');
      var backdrop = document.getElementById('searchBackdrop');
      var openBtn = document.getElementById('searchOpenBtn');
      var index = null;
      var activeIdx = -1;
      var colorHex = window.BOOLDER_COLOR_HEX;

      function ensureIndex(cb) {
        if (index) return cb();
        fetch('/assets/search-index.json').then(function(r) { return r.json(); }).then(function(data) { index = data; cb(); });
      }
      function normalize(str) { return str ? str.normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-zA-Z0-9]/g, '').toLowerCase() : ''; }
      function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

      function openModal() { modal.classList.remove('hidden'); input.value=''; results.classList.add('hidden'); results.innerHTML=''; clearBtn.classList.add('hidden'); activeIdx=-1; input.focus(); ensureIndex(function(){}); }
      function closeModal() { modal.classList.add('hidden'); input.value=''; results.classList.add('hidden'); results.innerHTML=''; activeIdx=-1; }

      function search() {
        var q = normalize(input.value.trim());
        if (!q || !index) { results.classList.add('hidden'); results.innerHTML=''; clearBtn.classList.add('hidden'); activeIdx=-1; return; }
        clearBtn.classList.remove('hidden');
        var tokens = q.match(/[a-z0-9]+/g) || [q];
        var areaHits = index.areas.filter(function(a) { return tokens.every(function(t) { return a.n.indexOf(t) !== -1; }); });
        var problemHits = index.problems.filter(function(p) { return tokens.every(function(t) { return p.n.indexOf(t) !== -1; }); });
        problemHits.sort(function(a, b) { return (b.pop||0) - (a.pop||0); });
        problemHits = problemHits.slice(0, 20);
        var items = [];
        areaHits.forEach(function(a) { items.push({type:'area', name:a.name, url:a.url}); });
        problemHits.forEach(function(p) { items.push({type:'problem', name:p.name, grade:p.grade, area:p.area, cc:p.cc, cn:p.cn, url:p.url}); });
        if (items.length === 0) { results.classList.add('hidden'); results.innerHTML=''; activeIdx=-1; return; }
        results.innerHTML = items.map(function(item, i) {
          if (item.type === 'area') return '<li class="search-result" data-url="'+esc(item.url)+'" data-i="'+i+'"><span class="search-result-name">'+esc(item.name)+'</span><span class="search-result-label">Area</span></li>';
          var bg = colorHex[item.cc]||'rgb(80%,80%,80%)'; var fg = item.cc==='white'?'#333':'#FFF';
          var circle = item.cc ? '<span class="badge--circuit-dot-sm" style="background:'+bg+';color:'+fg+';">'+(item.cn||'')+'</span>' : '';
          return '<li class="search-result" data-url="'+esc(item.url)+'" data-i="'+i+'"><div class="search-result-row"><div class="search-result-left">'+circle+'<span>'+esc(item.name)+'</span><span class="search-result-grade">'+(item.grade||'')+'</span></div><span class="search-result-area">'+esc(item.area)+'</span></div></li>';
        }).join('');
        results.classList.remove('hidden'); activeIdx=-1;
      }

      function setActive(i) {
        var lis = results.querySelectorAll('li');
        lis.forEach(function(li) { li.style.backgroundColor=''; });
        activeIdx = i;
        if (activeIdx >= 0 && activeIdx < lis.length) { lis[activeIdx].style.backgroundColor='var(--accent-bg)'; lis[activeIdx].scrollIntoView({block:'nearest'}); }
      }

      openBtn.addEventListener('click', openModal);
      backdrop.addEventListener('click', closeModal);
      cancelBtn.addEventListener('click', closeModal);
      clearBtn.addEventListener('click', function() { input.value=''; input.focus(); results.classList.add('hidden'); results.innerHTML=''; clearBtn.classList.add('hidden'); activeIdx=-1; });
      input.addEventListener('input', search);
      input.addEventListener('keydown', function(e) {
        var lis = results.querySelectorAll('li');
        if (e.key==='ArrowDown') { e.preventDefault(); setActive(Math.min(activeIdx+1, lis.length-1)); }
        else if (e.key==='ArrowUp') { e.preventDefault(); setActive(Math.max(activeIdx-1, 0)); }
        else if (e.key==='Enter' && activeIdx>=0 && activeIdx<lis.length) { e.preventDefault(); window.location=lis[activeIdx].getAttribute('data-url'); }
        else if (e.key==='Escape') closeModal();
      });
      results.addEventListener('click', function(e) { var li=e.target.closest('li'); if (li&&li.getAttribute('data-url')) window.location=li.getAttribute('data-url'); });
      document.addEventListener('keydown', function(e) {
        if (e.key==='/' && !modal.classList.contains('hidden')===false && document.activeElement.tagName!=='INPUT' && document.activeElement.tagName!=='TEXTAREA' && document.activeElement.tagName!=='SELECT') { e.preventDefault(); openModal(); }
      });
    })();
    </script>
  </body>
</html>
