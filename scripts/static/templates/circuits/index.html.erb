<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 mb-8">
  <div class="px-4 sm:px-0 pt-6">
    <div class="flex items-center space-x-1 text-sm font-medium text-gray-500 dark:text-gray-400">
      <a href="/<%= locale %>/fontainebleau" class="hover:text-gray-700 dark:hover:text-gray-300">Fontainebleau</a>
    </div>
  </div>

  <div class="lg:grid lg:grid-cols-2 lg:gap-16">
    <div class="col-span-1">
      <h1 class="text-3xl font-bold mb-4 mt-2 px-4 sm:px-0">Circuits</h1>
      <ul role="list">
        <%- (circuits || []).each do |c| -%>
          <li class="px-4 sm:-mx-2 sm:px-2 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg">
            <a href="/<%= locale %>/fontainebleau/circuits/<%= c["id"] %>" class="flex justify-between items-center">
              <div class="flex py-2 items-center">
                <%
                  color_map = {"yellow"=>"#FFCC02","purple"=>"#D783FF","orange"=>"#FF9500","green"=>"#77C344","blue"=>"#017AFF","skyblue"=>"#5AC7FA","salmon"=>"#FDAF8A","red"=>"#FF3B2F","black"=>"#000000","white"=>"#FFFFFF"}
                  bg = color_map[c["color"]] || "rgb(80% 80% 80%)"
                  fg = c["color"] == "white" ? "#333" : "#FFF"
                %>
                <span class="rounded-full h-6 w-6 leading-6 inline-flex justify-center" style="background-color: <%= bg %>; color: <%= fg %>;">&nbsp;</span>
                <span class="ml-2">Circuit <%= c["color"]&.capitalize %></span>
                <%- if c["main_area_name"] -%>
                  <span class="ml-2 text-gray-400 dark:text-gray-500"><%= c["main_area_name"] %></span>
                <%- end -%>
              </div>
              <span class="flex items-center space-x-2">
                <%- if c["dangerous"] -%>
                  <span class="text-red-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                  </span>
                <%- end -%>
                <%- if c["beginner_friendly"] -%>
                  <span class="text-emerald-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                  </span>
                <%- end -%>
                <span class="text-gray-500 dark:text-gray-400"><%= c["average_grade"] %></span>
              </span>
            </a>
          </li>
        <%- end -%>
      </ul>
    </div>
  </div>
</div>
