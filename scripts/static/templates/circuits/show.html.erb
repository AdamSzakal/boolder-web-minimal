<%
  hex = Static::ViewHelpers.circuit_hex(circuit["color"])
  text_col = Static::ViewHelpers.circuit_text_color(circuit["color"])
%>

<div class="container page-section">
  <div class="inner">
    <%= Static::ViewHelpers.breadcrumb(["Areas", "/areas"], [area["name"], "/areas/#{area["slug"]}"]) %>
  </div>
</div>

<div class="container page-section--bottom">
  <div>
    <div>
      <div>
        <h1 class="page-title inner">
          Circuit <%= circuit["color"].capitalize %>
        </h1>

        <%- if circuit["beginner_friendly"] -%>
          <span class="circuit-alert inner">
            <span class="icon-success"><%= Static::ViewHelpers::ICON_BEGINNER %></span>
            <span class="icon-success">Beginner friendly</span>
          </span>
        <%- end -%>

        <%- if circuit["dangerous"] -%>
          <span class="circuit-alert inner">
            <span class="icon-danger"><%= Static::ViewHelpers::ICON_DANGER %></span>
            <span class="icon-danger">Dangerous</span>
          </span>
        <%- end -%>

        <ul role="list" id="circuit-problems" class="boulder-list"></ul>
        <script>
        (function() {
          var problems = <%= problems_json %>;
          document.getElementById('circuit-problems').innerHTML = problems.map(function(p) {
            return renderBoulderItem(p);
          }).join('');
        })();
        </script>
      </div>
    </div>
  </div>
</div>
