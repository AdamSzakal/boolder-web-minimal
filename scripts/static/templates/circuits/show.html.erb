<%
  color_map = {"yellow"=>"#FFCC02","purple"=>"#D783FF","orange"=>"#FF9500","green"=>"#77C344","blue"=>"#017AFF","skyblue"=>"#5AC7FA","salmon"=>"#FDAF8A","red"=>"#FF3B2F","black"=>"#000000","white"=>"#FFFFFF"}
%>
<div class="max-w-7xl mx-auto pt-6 sm:px-6 lg:px-8">
  <div class="px-4 sm:px-0">
    <div class="flex items-center space-x-1 text-sm font-medium text-gray-500 dark:text-gray-400">
      <a href="/<%= locale %>/fontainebleau" class="hover:text-gray-700 dark:hover:text-gray-300">Fontainebleau</a>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
      <%- if area -%>
        <a href="/<%= locale %>/fontainebleau/<%= area["slug"] %>" class="hover:text-gray-700 dark:hover:text-gray-300"><%= area["name"] %></a>
      <%- end -%>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 pb-8">
  <div class="md:grid md:grid-cols-2 md:gap-16 mb-4">
    <div class="col-span-1">
      <h1 class="text-3xl font-bold mb-4 mt-2 px-4 sm:px-0">
        Circuit <%= circuit["color"]&.capitalize %>
      </h1>

      <%- if circuit["beginner_friendly"] -%>
        <span class="flex mb-2 px-4 sm:px-0">
          <span class="text-emerald-500 mr-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </span>
          <span class="text-emerald-500"><%= locale == "fr" ? "Adapté aux débutants" : "Beginner friendly" %></span>
        </span>
      <%- end -%>

      <%- if circuit["dangerous"] -%>
        <span class="flex mb-2 px-4 sm:px-0">
          <span class="text-red-500 mr-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </span>
          <span class="text-red-500"><%= locale == "fr" ? "Dangereux" : "Dangerous" %></span>
        </span>
      <%- end -%>

      <ul role="list" class="pt-2">
        <%- (problems || []).each do |p| -%>
          <li class="px-4 sm:-mx-2 sm:px-2 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg">
            <a href="/<%= locale %>/fontainebleau/<%= p["_area_slug"] || "" %>/<%= p["id"] %>">
              <div class="flex justify-between py-2">
                <div class="flex items-center">
                  <%
                    bg = color_map[p["circuit_color"]] || "rgb(80% 80% 80%)"
                    fg = p["circuit_color"] == "white" ? "#333" : "#FFF"
                  %>
                  <span class="rounded-full h-6 w-6 leading-6 inline-flex justify-center flex-shrink-0 text-sm" style="background-color: <%= bg %>; color: <%= fg %>;">
                    <%= p["circuit_number"] || "&nbsp;" %>
                  </span>
                  <span class="ml-2"><%= p["name"] %></span>
                </div>
                <div class="flex space-x-2">
                  <%- if p["featured"] -%>
                    <div class="text-red-400">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                      </svg>
                    </div>
                  <%- end -%>
                  <div class="text-gray-500 dark:text-gray-400"><%= p["grade"] %></div>
                </div>
              </div>
            </a>
          </li>
        <%- end -%>
      </ul>
    </div>
  </div>
</div>
