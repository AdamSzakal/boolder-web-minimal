<div class="max-w-7xl mx-auto pt-5 mt-1 px-4 sm:px-6 lg:px-8 bg-gray-100 dark:bg-gray-800 hidden sm:block mb-4">
  <a href="/<%= locale %>/fontainebleau" class="text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 flex items-center space-x-1">
    <div>Fontainebleau</div>
  </a>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8">
  <div class="lg:grid lg:grid-cols-2 lg:gap-16">
    <div class="col-span-1">
      <div class="aspect-w-16 aspect-h-9 relative overflow-hidden sm:rounded-lg">
        <div class="bg-no-repeat bg-cover bg-center" style="background-image: url(/media/area-covers/area-cover-<%= area["id"] %>.jpg);"></div>
        <div class="bg-transparent" style="background-image: linear-gradient(to top, rgba(0,0,0,0.2) 0%, rgba(0,0,0,0.1) 100%);"></div>
        <div class="absolute flex items-center text-center justify-center">
          <h1 class="text-4xl sm:text-4xl font-bold text-white uppercase px-4" style="text-shadow: 0px 0px 20px rgba(0,0,0,0.8)"><%= area["name"] %></h1>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 mb-8">
  <div class="lg:grid lg:grid-cols-2 lg:gap-16">
    <div class="col-span-1">
      <div>
        <div class="overflow-hidden bg-white dark:bg-gray-900 shadow sm:rounded-md sm:mt-4">
          <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
            <li>
              <div class="block">
                <div class="flex items-center px-4 py-3 sm:px-6">
                  <div class="flex min-w-0 flex-1 items-center">
                    <div class="flex justify-between w-full pr-2">
                      <div class="text-gray-700 dark:text-gray-300">
                        <%= area["problems_count"] %> <%= locale == "fr" ? "problèmes" : "problems" %>
                      </div>
                      <div class="flex space-x-1">
                        <%- (area["levels"] || {}).each do |level, count| -%>
                          <%- if count.to_i >= 20 -%>
                            <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-emerald-100 dark:bg-emerald-900 text-emerald-800 dark:text-emerald-200 text-xs font-medium"><%= level %></span>
                          <%- else -%>
                            <span class="inline-flex items-center justify-center h-5 w-5 rounded-full bg-gray-100 dark:bg-gray-700 text-gray-400 dark:text-gray-500 text-xs"><%= level %></span>
                          <%- end -%>
                        <%- end -%>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </li>
          </ul>
        </div>

        <div class="pt-2">
          <div class="px-4 sm:px-0 pt-2">
            <%- if (area["tags"] || []).any? -%>
              <div class="pt-4 pb-2 flex flex-wrap">
                <%- area["tags"].each do |tag| -%>
                  <span class="mt-2 mr-2 px-2.5 py-0.5 rounded-full border border-gray-700 dark:border-gray-500 text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-800 font-light text-sm">
                    <%= tag.gsub("_", " ") %>
                  </span>
                <%- end -%>
              </div>
            <%- end -%>

            <%- desc = area["description_#{locale}"] -%>
            <%- if desc && !desc.empty? -%>
              <div class="pt-4">
                <div class="prose dark:prose-invert text-justify">
                  <p><%= desc %></p>
                </div>
              </div>
            <%- end -%>

            <%- warning = area["warning_#{locale}"] -%>
            <%- if warning && !warning.empty? -%>
              <div class="pt-4">
                <div class="rounded-md bg-yellow-50 dark:bg-yellow-900/30 p-4">
                  <div class="flex">
                    <div class="flex-shrink-0">
                      <svg class="h-5 w-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 6a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 6zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <div class="ml-3">
                      <p class="text-sm text-yellow-700 dark:text-yellow-200"><%= warning %></p>
                    </div>
                  </div>
                </div>
              </div>
            <%- end -%>

            <a href="/<%= locale %>/map/<%= area["slug"] %>">
              <div class="flex items-center space-x-2 text-emerald-600 mt-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <div><%= locale == "fr" ? "Voir sur la carte" : "See on map" %></div>
              </div>
            </a>
          </div>

          <%- if circuits.any? -%>
            <div>
              <h2 class="text-2xl font-bold mt-8 mb-4 px-4 sm:px-0">Circuits</h2>
              <div class="overflow-hidden bg-white dark:bg-gray-900 shadow sm:rounded-md">
                <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
                  <%- circuits.each do |c| -%>
                    <li>
                      <a href="/<%= locale %>/fontainebleau/circuits/<%= c["id"] %>" class="block hover:bg-gray-50 dark:hover:bg-gray-800">
                        <div class="px-4 py-3 sm:px-6 flex items-center space-x-3">
                          <span class="inline-block h-4 w-4 rounded-full" style="background-color: <%= {"yellow"=>"#FFCC02","purple"=>"#D783FF","orange"=>"#FF9500","green"=>"#77C344","blue"=>"#017AFF","skyblue"=>"#5AC7FA","salmon"=>"#FDAF8A","red"=>"#FF3B2F","black"=>"#000","white"=>"#FFF"}[c["color"]] || "#ccc" %>;"></span>
                          <span class="text-gray-700 dark:text-gray-300"><%= c["color"].capitalize %></span>
                          <span class="text-gray-400 dark:text-gray-500"><%= c["average_grade"] %></span>
                        </div>
                      </a>
                    </li>
                  <%- end -%>
                </ul>
              </div>
            </div>
          <%- end -%>

          <%- if popular_problems.any? -%>
            <div>
              <div class="flex items-center space-x-2 text-2xl font-bold mt-8 mb-4 pt-4 px-4 sm:px-0">
                <h2><%= locale == "fr" ? "Problèmes populaires" : "Popular problems" %></h2>
                <span class="text-red-400">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" />
                  </svg>
                </span>
              </div>
              <div class="overflow-hidden bg-white dark:bg-gray-900 shadow sm:rounded-md">
                <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
                  <%- popular_problems.each do |p| -%>
                    <li>
                      <a href="/<%= locale %>/fontainebleau/<%= area["slug"] %>/<%= p["id"] %>" class="block hover:bg-gray-50 dark:hover:bg-gray-800">
                        <div class="px-4 py-3 sm:px-6 flex justify-between items-center">
                          <span class="font-medium text-gray-900 dark:text-gray-100"><%= p["name"] %></span>
                          <span class="text-gray-400 dark:text-gray-500"><%= p["grade"] %></span>
                        </div>
                      </a>
                    </li>
                  <%- end -%>
                </ul>
              </div>
            </div>
          <%- end -%>

          <%- if poi_routes.any? -%>
            <div>
              <h2 class="text-2xl font-bold mt-8 mb-4 pt-4 px-4 sm:px-0">
                <%= locale == "fr" ? "Accès" : "Access" %>
              </h2>
              <ul class="pt-2 px-4 sm:px-0">
                <%- poi_routes.each do |r| -%>
                  <%- poi = r["poi"] -%>
                  <%- next unless poi -%>
                  <li class="flex justify-between text-gray-700 dark:text-gray-300 mb-4">
                    <a href="<%= poi["google_url"] %>" target="_blank" class="flex space-x-1 items-center">
                      <span>
                        <%- if poi["poi_type"] == "parking" -%>
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 10l7-7m0 0l7 7m-7-7v18" /></svg>
                        <%- else -%>
                          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>
                        <%- end -%>
                      </span>
                      <span><%= poi["short_name"] || poi["name"] %></span>
                    </a>
                    <span class="flex space-x-1 items-center text-gray-400 dark:text-gray-500">
                      <span>
                        <%- if r["transport"] == "bike" -%>
                          🚲
                        <%- else -%>
                          🚶
                        <%- end -%>
                      </span>
                      <%- distance = r["distance"].to_i -%>
                      <%- minutes = r["transport"] == "bike" ? (distance / 240.0).ceil : (distance / 80.0).ceil -%>
                      <%- minutes = [minutes, 2].max -%>
                      <span><%= minutes %> min</span>
                    </span>
                  </li>
                <%- end -%>
              </ul>
            </div>
          <%- end -%>
        </div>
      </div>
    </div>
  </div>
</div>
