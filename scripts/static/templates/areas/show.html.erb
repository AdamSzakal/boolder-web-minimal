<%
  description = area["description_en"]
  warning = area["warning_en"]
  color_hex = { "yellow" => "#FFCC02", "purple" => "#D783FF", "orange" => "#FF9500", "green" => "#77C344", "blue" => "#017AFF", "skyblue" => "#5AC7FA", "salmon" => "#FDAF8A", "red" => "#FF3B2F", "black" => "#000000", "white" => "#FFFFFF" }
%>

<div class="max-w-7xl mx-auto pt-5 mt-1 px-4 sm:px-6 lg:px-8 bg-gray-100 dark:bg-gray-800 hidden sm:block mb-4">
  <a href="/en/fontainebleau" class="text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 flex items-center space-x-1">
    <div>Fontainebleau</div>
  </a>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8">
  <div class="lg:grid lg:grid-cols-2 lg:gap-16">
    <div class="col-span-1">
      <div class="aspect-w-16 aspect-h-9 relative overflow-hidden sm:rounded-lg">
        <%- if cover_image_url -%>
          <img src="<%= cover_image_url %>" alt="<%= area["name"] %>" class="w-full h-full object-cover" loading="lazy" />
        <%- else -%>
          <div class="bg-gradient-to-br from-emerald-600 to-emerald-800 w-full h-full"></div>
        <%- end -%>
        <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.1) 100%);"></div>
        <div class="absolute inset-0 flex items-center justify-center">
          <h1 class="text-4xl sm:text-4xl font-bold text-white uppercase px-4" style="text-shadow: 0px 0px 20px rgba(0,0,0,0.8)"><%= area["name"] %></h1>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 mb-8">
  <div class="lg:grid lg:grid-cols-2 lg:gap-16">
    <div class="col-span-1">
      <div>
        <div class="overflow-hidden bg-white dark:bg-gray-900 shadow sm:rounded-md sm:mt-4">
          <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
            <li>
              <div class="block">
                <div class="flex items-center px-4 py-3 sm:px-6">
                  <div class="flex min-w-0 flex-1 items-center">
                    <div class="flex justify-between w-full pr-2">
                      <div class="text-gray-700 dark:text-gray-300">
                        <%= area["problems_count"] %> problems
                      </div>
                      <div class="flex space-x-1">
                        <%- 1.upto(8) do |level| -%>
                          <%- count = area["level#{level}_count"] || 0 -%>
                          <span class="inline-block w-5 h-5 rounded text-center text-xs leading-5 font-medium <%= count >= 20 ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900 dark:text-emerald-200' : 'bg-gray-100 text-gray-400 dark:bg-gray-800 dark:text-gray-600' %>">
                            <%= level %>
                          </span>
                        <%- end -%>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </li>
          </ul>
        </div>

        <div class="pt-2">
          <div class="px-4 sm:px-0 pt-2">
            <%- if area["tags"] && area["tags"].any? -%>
              <div class="pt-4 pb-2 flex flex-wrap">
                <%- tag_labels = { "popular" => "Popular", "beginner_friendly" => "Beginner friendly", "family_friendly" => "Family friendly", "dry_fast" => "Dries fast" } -%>
                <%- area["tags"].each do |tag| -%>
                  <span class="mt-2 mr-2 px-2.5 py-0.5 rounded-full border border-gray-700 dark:border-gray-500 text-gray-700 dark:text-gray-300 bg-gray-50 dark:bg-gray-800 font-light text-sm">
                    <%= tag_labels[tag] || tag %>
                  </span>
                <%- end -%>
              </div>
            <%- end -%>

            <%- if description.to_s.strip.length > 0 -%>
              <div class="pt-4">
                <div class="prose dark:prose-invert text-justify">
                  <%- description.split(/\r?\n\r?\n/).each do |para| -%>
                    <p><%= para.strip %></p>
                  <%- end -%>
                </div>
              </div>
            <%- end -%>

            <%- if warning.to_s.strip.length > 0 -%>
              <div class="pt-4">
                <div class="rounded-md bg-yellow-50 dark:bg-yellow-900/30 p-4">
                  <div class="flex">
                    <div class="flex-shrink-0">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <div class="ml-3 text-sm text-yellow-700 dark:text-yellow-200">
                      <%- warning.split(/\r?\n\r?\n/).each do |para| -%>
                        <p><%= para.strip %></p>
                      <%- end -%>
                    </div>
                  </div>
                </div>
              </div>
            <%- end -%>

            <a href="/en/map/<%= area["slug"] %>">
              <div class="flex items-center space-x-2 text-emerald-600 mt-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <div>See on map</div>
              </div>
            </a>
          </div>

          <%- if circuits && circuits.any? -%>
            <div>
              <h2 class="text-2xl font-bold mt-8 mb-4 px-4 sm:px-0">Circuits</h2>
              <ul role="list">
                <%- circuits.each do |circuit| -%>
                  <%
                    hex = color_hex[circuit["color"]] || "#999"
                    text_col = circuit["color"] == "white" ? "#000" : "#FFF"
                  %>
                  <li class="px-4 sm:-mx-2 sm:px-2 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg">
                    <a href="/en/fontainebleau/circuits/<%= circuit["id"] %>" class="flex justify-between items-center">
                      <div class="flex justify-between py-2">
                        <div>
                          <span class="inline-block w-4 h-4 rounded-full" style="background-color: <%= hex %>;"></span>
                          <span class="ml-2">Circuit <%= circuit["color"].capitalize %></span>
                        </div>
                      </div>
                      <span class="flex">
                        <%- if circuit["dangerous"] -%>
                          <span class="flex text-red-500 mr-2" title="Dangerous">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                            </svg>
                          </span>
                        <%- end -%>
                        <%- if circuit["beginner_friendly"] -%>
                          <span class="flex text-emerald-500 mr-2" title="Beginner friendly">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                          </span>
                        <%- end -%>
                        <span class="text-gray-500 dark:text-gray-400"><%= circuit["average_grade"] %></span>
                      </span>
                    </a>
                  </li>
                <%- end -%>
              </ul>
            </div>
          <%- end -%>

          <div>
            <div class="flex items-center space-x-2 text-2xl font-bold mt-8 mb-4 pt-4 px-4 sm:px-0">
              <h2>Popular problems</h2>
              <span class="text-red-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M11.645 20.91l-.007-.003-.022-.012a15.247 15.247 0 01-.383-.218 25.18 25.18 0 01-4.244-3.17C4.688 15.36 2.25 12.174 2.25 8.25 2.25 5.322 4.714 3 7.688 3A5.5 5.5 0 0112 5.052 5.5 5.5 0 0116.313 3c2.973 0 5.437 2.322 5.437 5.25 0 3.925-2.438 7.111-4.739 9.256a25.175 25.175 0 01-4.244 3.17 15.247 15.247 0 01-.383.219l-.022.012-.007.004-.003.001a.752.752 0 01-.704 0l-.003-.001z" />
                </svg>
              </span>
            </div>
            <ul role="list">
              <%- popular_problems.each do |problem| -%>
                <%
                  problem_slug = [problem["id"], problem["name"]&.downcase&.gsub(/[^a-z0-9]+/, "-")&.gsub(/-$/, "")].compact.join("-")
                %>
                <li class="px-4 sm:-mx-2 sm:px-2 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg">
                  <a href="/en/fontainebleau/<%= area["slug"] %>/<%= problem_slug %>">
                    <div class="flex justify-between py-2">
                      <div>
                        <%- if problem["circuit_color"] && problem["circuit_number"] -%>
                          <%
                            c_hex = color_hex[problem["circuit_color"]] || "#999"
                            c_text = problem["circuit_color"] == "white" ? "#000" : "#FFF"
                          %>
                          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full text-xs font-bold" style="background-color: <%= c_hex %>; color: <%= c_text %>;"><%= problem["circuit_number"] %></span>
                        <%- else -%>
                          <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-200 dark:bg-gray-700 text-xs">&nbsp;</span>
                        <%- end -%>
                        <span class="ml-2"><%= problem["name"] %></span>
                      </div>
                      <div class="text-gray-500 dark:text-gray-400">
                        <%= problem["grade"] %>
                      </div>
                    </div>
                  </a>
                </li>
              <%- end -%>
            </ul>
          </div>

          <%- if poi_routes && poi_routes.any? -%>
            <div>
              <h2 class="text-2xl font-bold mt-8 mb-4 pt-4 px-4 sm:px-0">Access</h2>
              <ul class="pt-2 px-4 sm:px-0">
                <%- poi_routes.sort_by { |r| r["distance"] || 0 }.each do |route| -%>
                  <%
                    poi = route["poi"]
                    next unless poi
                    minutes = if route["transport"] == "bike"
                      [route["distance"].to_i / 240, 2].max
                    else
                      [route["distance"].to_i / 80, 2].max
                    end
                    transport_icon = route["transport"] == "bike" ? "🚲" : "🚶"
                    poi_icon = poi["poi_type"] == "train_station" ? "🚉" : "🅿️"
                  %>
                  <li class="flex justify-between text-gray-700 dark:text-gray-300 mb-4">
                    <a href="<%= poi["google_url"] %>" target="_blank" class="flex space-x-1 items-center">
                      <span><%= poi_icon %></span>
                      <span><%= poi["short_name"] %></span>
                    </a>
                    <span class="flex space-x-1 items-center">
                      <span><%= transport_icon %></span>
                      <span><%= minutes %> min</span>
                    </span>
                  </li>
                <%- end -%>
              </ul>
            </div>
          <%- end -%>
        </div>
      </div>
    </div>
  </div>
</div>
