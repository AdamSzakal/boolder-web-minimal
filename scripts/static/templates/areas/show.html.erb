<%
  description = area["description_en"]
  warning = area["warning_en"]
%>

<div class="container pt-6 hidden" style="padding-top:1.25rem;margin-top:0.25rem;background:var(--bg-secondary);">
  <a href="/en/fontainebleau" class="breadcrumb" style="display:inline-flex;">
    <div>Fontainebleau</div>
  </a>
</div>

<div class="container">
  <div class="two-col">
    <div>
      <div class="cover-image">
        <%- if cover_image_url -%>
          <img src="<%= cover_image_url %>" alt="<%= area["name"] %>" loading="lazy" />
        <%- else -%>
          <div class="cover-image-placeholder"></div>
        <%- end -%>
        <div class="cover-image-overlay"></div>
        <div class="cover-image-title">
          <h1><%= area["name"] %></h1>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="container mb-8">
  <div class="two-col">
    <div>
      <div>
        <div class="card" style="margin-top:1rem;">
          <ul role="list" class="divide-y">
            <li>
              <div style="display:flex;align-items:center;padding:0.75rem 1rem;">
                <div style="display:flex;min-width:0;flex:1;align-items:center;">
                  <div style="display:flex;justify-content:space-between;width:100%;padding-right:0.5rem;">
                    <div class="text-muted">
                      <%= area["problems_count"] %> problems
                    </div>
                    <div style="display:flex;gap:0.25rem;">
                      <%- 1.upto(8) do |level| -%>
                        <%- count = area["level#{level}_count"] || 0 -%>
                        <span class="grade-cell <%= count >= 20 ? 'grade-cell--active' : 'grade-cell--inactive' %>">
                          <%= level %>
                        </span>
                      <%- end -%>
                    </div>
                  </div>
                </div>
              </div>
            </li>
          </ul>
        </div>

        <div class="pt-2">
          <div class="inner pt-2">
            <%- if area["tags"] && area["tags"].any? -%>
              <div class="pt-4 pb-2 flex flex-wrap">
                <%- tag_labels = { "popular" => "Popular", "beginner_friendly" => "Beginner friendly", "family_friendly" => "Family friendly", "dry_fast" => "Dries fast" } -%>
                <%- area["tags"].each do |tag| -%>
                  <span class="badge--tag"><%= tag_labels[tag] || tag %></span>
                <%- end -%>
              </div>
            <%- end -%>

            <%- if description.to_s.strip.length > 0 -%>
              <div class="pt-4">
                <div class="prose">
                  <%- description.split(/\r?\n\r?\n/).each do |para| -%>
                    <p><%= para.strip %></p>
                  <%- end -%>
                </div>
              </div>
            <%- end -%>

            <%- if warning.to_s.strip.length > 0 -%>
              <div class="pt-4">
                <div class="warning-box">
                  <div>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                      <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <div class="warning-box-text">
                    <%- warning.split(/\r?\n\r?\n/).each do |para| -%>
                      <p><%= para.strip %></p>
                    <%- end -%>
                  </div>
                </div>
              </div>
            <%- end -%>

            <%= Static::ViewHelpers.action_link("/en/map/#{area["slug"]}", Static::ViewHelpers::ICON_MAP_PIN, "See on map") %>
          </div>

          <%- if circuits && circuits.any? -%>
            <div>
              <h2 class="section-title mt-8 mb-4 inner">Circuits</h2>
              <ul role="list">
                <%- circuits.each do |circuit| -%>
                  <%= render_partial("circuit_list_item", "circuit" => circuit) %>
                <%- end -%>
              </ul>
            </div>
          <%- end -%>

          <div>
            <div class="flex items-center space-x-2 mt-8 mb-4 pt-4 inner">
              <h2 class="section-title">Popular problems</h2>
              <span class="text-red-400"><%= Static::ViewHelpers::ICON_HEART %></span>
            </div>
            <ul role="list">
              <%- popular_problems.each do |problem| -%>
                <%= render_partial("problem_list_item", "problem" => problem, "area_slug" => area["slug"]) %>
              <%- end -%>
            </ul>
          </div>

          <%- if poi_routes && poi_routes.any? -%>
            <div>
              <h2 class="section-title mt-8 mb-4 pt-4 inner">Access</h2>
              <ul class="pt-2 inner">
                <%- poi_routes.sort_by { |r| r["distance_in_minutes"] || 0 }.each do |route| -%>
                  <%
                    poi = route["poi"]
                    next unless poi
                    minutes = [route["distance_in_minutes"].to_i, 1].max
                    transport_icon = route["transport"] == "bike" ? "🚲" : "🚶"
                    poi_icon = poi["poi_type"] == "train_station" ? "🚉" : "🅿️"
                  %>
                  <li class="poi-item">
                    <a href="<%= poi["google_url"] %>" target="_blank" class="poi-link">
                      <span><%= poi_icon %></span>
                      <span><%= poi["short_name"] %></span>
                    </a>
                    <span class="poi-link">
                      <span><%= transport_icon %></span>
                      <span><%= minutes %> min</span>
                    </span>
                  </li>
                <%- end -%>
              </ul>
            </div>
          <%- end -%>
        </div>
      </div>
    </div>
  </div>
</div>
