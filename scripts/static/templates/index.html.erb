<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 mt-8">
  <h1 class="text-3xl font-bold mt-8 mb-4 px-4 sm:px-0">Fontainebleau</h1>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 pb-8">
  <div class="lg:grid lg:grid-cols-2 lg:gap-16 mb-4">
    <div class="col-span-1">
      <h2 class="py-4 px-4 sm:px-0 text-2xl font-bold text-gray-900 dark:text-gray-100">
        <%= locale == "fr" ? "Tous les secteurs" : "All areas" %>
      </h2>

      <div class="overflow-hidden bg-white dark:bg-gray-900 shadow ring-1 ring-black ring-opacity-5 dark:ring-gray-600 md:rounded-lg">
        <ul role="list" class="divide-y divide-gray-200 dark:divide-gray-700">
          <%- (areas || []).each do |area| -%>
            <li>
              <a href="/<%= locale %>/fontainebleau/<%= area["slug"] %>" class="block hover:bg-gray-50 dark:hover:bg-gray-800">
                <div class="px-4 py-4 sm:px-6">
                  <div class="flex justify-between">
                    <p class="text-gray-900 dark:text-gray-100"><%= area["name"] %></p>
                    <div class="flex items-center space-x-2 text-gray-400 dark:text-gray-500">
                      <span><%= area["problems_count"] %></span>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          <%- end -%>
        </ul>
      </div>
    </div>
  </div>
</div>
