<div class="max-w-7xl mx-auto pt-6 sm:px-6 lg:px-8">
  <div class="px-4 sm:px-0">
    <div class="flex items-center space-x-1 text-sm font-medium text-gray-500 dark:text-gray-400">
      <div><a href="/en/fontainebleau" class="hover:text-gray-700 dark:hover:text-gray-300">Fontainebleau</a></div>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto sm:px-6 lg:px-8 mb-8">
  <h1 class="text-3xl font-bold mt-2 mb-4 px-4 sm:px-0">Boulders</h1>
  <div class="lg:grid lg:grid-cols-2 lg:gap-16 mt-4">
    <div class="col-span-1">
      <!-- Filters -->
      <div class="px-4 sm:px-0 space-y-4" id="boulders-filters">
        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Grade</label>
          <select id="filter-grade" class="mt-1 block w-full md:w-1/3 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm">
            <option value="">All</option>
            <option value="beginner">Beginner (1–3)</option>
            <option value="level4">Level 4</option>
            <option value="level5">Level 5</option>
            <option value="level6">Level 6</option>
            <option value="level7">Level 7</option>
            <option value="level8">Level 8+</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Steepness</label>
          <select id="filter-steepness" class="mt-1 block w-full md:w-1/3 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm">
            <option value="">All</option>
            <option value="wall">Wall</option>
            <option value="slab">Slab</option>
            <option value="overhang">Overhang</option>
            <option value="roof">Roof</option>
            <option value="traverse">Traverse</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Circuit</label>
          <select id="filter-circuit" class="mt-1 block w-full md:w-1/2 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm">
            <option value="">All</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Sort by</label>
          <div class="flex items-center space-x-2 mt-1">
            <select id="filter-sort" class="block w-full md:w-1/3 rounded-md border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 dark:text-gray-100 py-2 pl-3 pr-10 text-base focus:border-emerald-500 focus:outline-none focus:ring-emerald-500 sm:text-sm">
              <option value="popularity">Popularity</option>
              <option value="grade">Grade</option>
            </select>
            <button id="filter-direction" type="button" class="inline-flex items-center p-2 rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 hover:bg-gray-50 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400" title="Toggle sort direction">
              <svg id="dir-desc-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h9m5-4v12m0 0l-4-4m4 4l4-4" />
              </svg>
              <svg id="dir-asc-icon" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div id="results-count" class="px-4 sm:px-0 pt-4 text-sm text-gray-500 dark:text-gray-400"></div>

      <ul role="list" id="boulders-list"></ul>
    </div>
  </div>
</div>

<script>
(function() {
  const allProblems = <%= problems_json %>;
  const allCircuits = <%= circuits_json %>;

  const colorHex = {
    yellow: "#FFCC02", purple: "#D783FF", orange: "#FF9500",
    green: "#77C344", blue: "#017AFF", skyblue: "#5AC7FA",
    salmon: "#FDAF8A", red: "#FF3B2F", black: "#000000", white: "#FFFFFF"
  };
  const steepnessLabels = {
    wall: "Wall", slab: "Slab", overhang: "Overhang",
    roof: "Roof", traverse: "Traverse", other: "Other"
  };
  const allGrades = ["1a","1a+","1b","1b+","1c","1c+","2a","2a+","2b","2b+","2c","2c+","3a","3a+","3b","3b+","3c","3c+","4a","4a+","4b","4b+","4c","4c+","5a","5a+","5b","5b+","5c","5c+","6a","6a+","6b","6b+","6c","6c+","7a","7a+","7b","7b+","7c","7c+","8a","8a+","8b","8b+","8c","8c+","9a","9a+","9b","9b+","9c","9c+"];

  const gradeRanges = {
    beginner: new Set(allGrades.slice(0, 18)),
    level4: new Set(allGrades.slice(18, 24)),
    level5: new Set(allGrades.slice(24, 30)),
    level6: new Set(allGrades.slice(30, 36)),
    level7: new Set(allGrades.slice(36, 42)),
    level8: new Set(allGrades.slice(42)),
  };

  // Populate circuit dropdown
  const circuitEl = document.getElementById('filter-circuit');
  allCircuits.forEach(c => {
    const opt = document.createElement('option');
    opt.value = c.id;
    opt.textContent = c.area_name + ' \u2013 ' + capitalize(c.color);
    circuitEl.appendChild(opt);
  });

  const gradeEl = document.getElementById('filter-grade');
  const steepnessEl = document.getElementById('filter-steepness');
  const sortEl = document.getElementById('filter-sort');
  const dirBtn = document.getElementById('filter-direction');
  const listEl = document.getElementById('boulders-list');
  const countEl = document.getElementById('results-count');
  const descIcon = document.getElementById('dir-desc-icon');
  const ascIcon = document.getElementById('dir-asc-icon');

  let direction = 'desc';

  function gradeIndex(g) { return allGrades.indexOf(g); }

  function circuitSortKey(p) {
    // Parse circuit_number as float for sorting ("D" → -1, "1" → 1, etc.)
    if (!p.circuit_number) return 9999;
    if (p.circuit_number === 'D') return -1;
    return parseFloat(p.circuit_number) || 9999;
  }

  function applyFilters() {
    const gradeFilter = gradeEl.value;
    const steepnessFilter = steepnessEl.value;
    const circuitFilter = circuitEl.value;
    const sortBy = sortEl.value;

    let filtered = allProblems;

    // When browsing a circuit, show all problems in it; otherwise only popular ones
    if (circuitFilter) {
      filtered = filtered.filter(p => p.circuit_id === parseInt(circuitFilter));
    } else {
      filtered = filtered.filter(p => p.popularity >= 1);
    }

    if (gradeFilter && gradeRanges[gradeFilter]) {
      const allowed = gradeRanges[gradeFilter];
      filtered = filtered.filter(p => allowed.has(p.grade));
    }

    if (steepnessFilter) {
      filtered = filtered.filter(p => p.steepness === steepnessFilter);
    }

    // Sort: circuit order when a circuit is selected, otherwise by chosen sort
    if (circuitFilter) {
      filtered.sort((a, b) => {
        const cmp = circuitSortKey(a) - circuitSortKey(b);
        return direction === 'asc' ? -cmp : cmp;
      });
    } else {
      filtered.sort((a, b) => {
        let cmp;
        if (sortBy === 'grade') {
          cmp = gradeIndex(a.grade) - gradeIndex(b.grade);
          if (cmp === 0) cmp = (b.popularity || 0) - (a.popularity || 0);
        } else {
          cmp = (b.popularity || 0) - (a.popularity || 0);
        }
        return direction === 'asc' ? -cmp : cmp;
      });
    }

    // Limit display to 200
    const display = filtered.slice(0, 200);

    countEl.textContent = filtered.length + ' problems' + (filtered.length > 200 ? ' (showing first 200)' : '');

    listEl.innerHTML = display.map(p => {
      const cHex = colorHex[p.circuit_color] || '';
      const cText = p.circuit_color === 'white' ? '#000' : '#FFF';
      const circuitBadge = p.circuit_color
        ? '<span class="inline-flex items-center rounded-full px-2 py-0.5" style="background-color: ' + cHex + '; color: ' + cText + ';">' + capitalize(p.circuit_color) + (p.circuit_number ? ' ' + p.circuit_number : '') + '</span>'
        : '';

      return '<li class="px-4 sm:-mx-2 sm:px-2 hover:bg-gray-50 dark:hover:bg-gray-800 rounded-lg">' +
        '<a href="' + p.url + '">' +
          '<div class="py-2">' +
            '<div><span>' + esc(p.name) + '</span> <span class="ml-1 text-gray-500 dark:text-gray-400">' + (p.grade || '') + '</span></div>' +
            '<div class="flex flex-wrap items-center gap-1.5 text-xs text-gray-500 dark:text-gray-400 mt-1">' +
              (p.popularity > 0 ? '<span class="inline-flex items-center gap-1 rounded-full bg-gray-200 dark:bg-gray-700 px-2 py-0.5">\u2605 ' + p.popularity + '</span>' : '') +
              '<span class="inline-flex items-center rounded-full bg-gray-200 dark:bg-gray-700 px-2 py-0.5">' + (steepnessLabels[p.steepness] || p.steepness) + '</span>' +
              '<span class="inline-flex items-center rounded-full bg-gray-200 dark:bg-gray-700 px-2 py-0.5">' + esc(p.area_name) + '</span>' +
              circuitBadge +
            '</div>' +
          '</div>' +
        '</a>' +
      '</li>';
    }).join('');
  }

  function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }
  function esc(s) { return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

  gradeEl.addEventListener('change', applyFilters);
  steepnessEl.addEventListener('change', applyFilters);
  circuitEl.addEventListener('change', () => {
    // When a circuit is selected, auto-switch sort to ascending (circuit order reads naturally 1→N)
    if (circuitEl.value) {
      direction = 'asc';
      descIcon.classList.add('hidden');
      ascIcon.classList.remove('hidden');
    }
    applyFilters();
  });
  sortEl.addEventListener('change', applyFilters);
  dirBtn.addEventListener('click', () => {
    direction = direction === 'desc' ? 'asc' : 'desc';
    descIcon.classList.toggle('hidden', direction === 'asc');
    ascIcon.classList.toggle('hidden', direction === 'desc');
    applyFilters();
  });

  // Initial render
  applyFilters();
})();
</script>
