<div class="container page-section">
  <div class="inner">
    <%= Static::ViewHelpers.breadcrumb(["Fontainebleau", "/en/fontainebleau"]) %>
  </div>
</div>

<div class="container page-section--bottom">
  <h1 class="page-title inner">Boulders</h1>
  <div class="content-section--lg">
    <div>
      <!-- Filters -->
      <div class="inner filters-stack" id="boulders-filters">
        <div>
          <label class="filter-label">Grade</label>
          <select id="filter-grade" class="filter-select filter-select--narrow">
            <option value="">All</option>
            <option value="beginner">Beginner (1–3)</option>
            <option value="level4">Level 4</option>
            <option value="level5">Level 5</option>
            <option value="level6">Level 6</option>
            <option value="level7">Level 7</option>
            <option value="level8">Level 8+</option>
          </select>
        </div>

        <div>
          <label class="filter-label">Steepness</label>
          <select id="filter-steepness" class="filter-select filter-select--narrow">
            <option value="">All</option>
            <option value="wall">Wall</option>
            <option value="slab">Slab</option>
            <option value="overhang">Overhang</option>
            <option value="roof">Roof</option>
            <option value="traverse">Traverse</option>
          </select>
        </div>

        <div>
          <label class="filter-label">Area</label>
          <select id="filter-area" class="filter-select filter-select--narrow">
            <option value="">All</option>
          </select>
        </div>

        <div>
          <label class="filter-label">Circuit</label>
          <select id="filter-circuit" class="filter-select filter-select--medium">
            <option value="">All</option>
          </select>
        </div>

        <div>
          <label class="filter-label">Sort by</label>
          <div class="sort-row">
            <select id="filter-sort" class="filter-select filter-select--narrow">
              <option value="popularity">Popularity</option>
              <option value="grade">Grade</option>
              <option value="distance">Distance</option>
            </select>
            <button id="filter-direction" type="button" class="sort-dir-btn" title="Toggle sort direction">
              <svg id="dir-desc-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h9m5-4v12m0 0l-4-4m4 4l4-4" />
              </svg>
              <svg id="dir-asc-icon" xmlns="http://www.w3.org/2000/svg" class="hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div id="results-count" class="inner results-count"></div>

      <ul role="list" id="boulders-list"></ul>
    </div>
  </div>
</div>

<script>
(function() {
  var allProblems = <%= problems_json %>;
  var allCircuits = <%= circuits_json %>;

  var colorHex = window.BOOLDER_COLOR_HEX;
  var steepnessLabels = window.BOOLDER_STEEPNESS_LABELS;

  var allGrades = ["1a","1a+","1b","1b+","1c","1c+","2a","2a+","2b","2b+","2c","2c+","3a","3a+","3b","3b+","3c","3c+","4a","4a+","4b","4b+","4c","4c+","5a","5a+","5b","5b+","5c","5c+","6a","6a+","6b","6b+","6c","6c+","7a","7a+","7b","7b+","7c","7c+","8a","8a+","8b","8b+","8c","8c+","9a","9a+","9b","9b+","9c","9c+"];

  var gradeRanges = {
    beginner: new Set(allGrades.slice(0, 18)),
    level4: new Set(allGrades.slice(18, 24)),
    level5: new Set(allGrades.slice(24, 30)),
    level6: new Set(allGrades.slice(30, 36)),
    level7: new Set(allGrades.slice(36, 42)),
    level8: new Set(allGrades.slice(42)),
  };

  // Populate area dropdown from problem data
  var areaEl = document.getElementById('filter-area');
  var areaNames = {};
  allProblems.forEach(function(p) { if (p.area_name) areaNames[p.area_name] = 1; });
  Object.keys(areaNames).sort().forEach(function(name) {
    var opt = document.createElement('option');
    opt.value = name;
    opt.textContent = name;
    areaEl.appendChild(opt);
  });

  var circuitEl = document.getElementById('filter-circuit');

  function populateCircuits(areaFilter) {
    var prev = circuitEl.value;
    circuitEl.innerHTML = '<option value="">All</option>';
    var circuits = areaFilter
      ? allCircuits.filter(function(c) { return c.area_name === areaFilter; })
      : allCircuits;
    circuits.forEach(function(c) {
      var opt = document.createElement('option');
      opt.value = c.id;
      // Skip area prefix when already filtered to a single area
      opt.textContent = areaFilter ? capitalize(c.color) : c.area_name + ' \u2013 ' + capitalize(c.color);
      circuitEl.appendChild(opt);
    });
    // Restore previous selection if it still exists
    circuitEl.value = prev;
    if (!circuitEl.value) circuitEl.value = '';
  }

  populateCircuits('');

  var gradeEl = document.getElementById('filter-grade');
  var steepnessEl = document.getElementById('filter-steepness');
  var sortEl = document.getElementById('filter-sort');
  var dirBtn = document.getElementById('filter-direction');
  var listEl = document.getElementById('boulders-list');
  var countEl = document.getElementById('results-count');
  var descIcon = document.getElementById('dir-desc-icon');
  var ascIcon = document.getElementById('dir-asc-icon');

  var direction = 'desc';
  var userLat = null, userLng = null;

  function gradeIndex(g) { return allGrades.indexOf(g); }

  function circuitSortKey(p) {
    if (!p.circuit_number) return 9999;
    if (p.circuit_number === 'D') return -1;
    return parseFloat(p.circuit_number) || 9999;
  }

  function distKm(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLng = (lng2 - lng1) * Math.PI / 180;
    var a = Math.sin(dLat/2) * Math.sin(dLat/2) +
      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
      Math.sin(dLng/2) * Math.sin(dLng/2);
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  function applyFilters() {
    var gradeFilter = gradeEl.value;
    var steepnessFilter = steepnessEl.value;
    var areaFilter = areaEl.value;
    var circuitFilter = circuitEl.value;
    var sortBy = sortEl.value;

    var filtered = allProblems;

    if (circuitFilter) {
      filtered = filtered.filter(function(p) { return p.circuit_id === parseInt(circuitFilter); });
    } else {
      filtered = filtered.filter(function(p) { return p.popularity >= 1; });
    }

    if (areaFilter) {
      filtered = filtered.filter(function(p) { return p.area_name === areaFilter; });
    }

    if (gradeFilter && gradeRanges[gradeFilter]) {
      var allowed = gradeRanges[gradeFilter];
      filtered = filtered.filter(function(p) { return allowed.has(p.grade); });
    }

    if (steepnessFilter) {
      filtered = filtered.filter(function(p) { return p.steepness === steepnessFilter; });
    }

    if (circuitFilter) {
      filtered.sort(function(a, b) {
        var cmp = circuitSortKey(a) - circuitSortKey(b);
        return direction === 'asc' ? -cmp : cmp;
      });
    } else if (sortBy === 'distance' && userLat !== null) {
      filtered.forEach(function(p) { p._dist = distKm(userLat, userLng, p.lat, p.lng); });
      filtered.sort(function(a, b) {
        var cmp = a._dist - b._dist;
        return direction === 'asc' ? -cmp : cmp;
      });
    } else {
      filtered.sort(function(a, b) {
        var cmp;
        if (sortBy === 'grade') {
          cmp = gradeIndex(a.grade) - gradeIndex(b.grade);
          if (cmp === 0) cmp = (b.popularity || 0) - (a.popularity || 0);
        } else {
          cmp = (b.popularity || 0) - (a.popularity || 0);
        }
        return direction === 'asc' ? -cmp : cmp;
      });
    }

    var display = filtered.slice(0, 200);
    countEl.textContent = filtered.length + ' problems' + (filtered.length > 200 ? ' (showing first 200)' : '');

    listEl.innerHTML = display.map(function(p) {
      return renderBoulderItem(p);
    }).join('');
  }

  function capitalize(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }
  function esc(s) { return (s || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;'); }

  gradeEl.addEventListener('change', applyFilters);
  steepnessEl.addEventListener('change', applyFilters);
  areaEl.addEventListener('change', function() {
    populateCircuits(areaEl.value);
    applyFilters();
  });
  circuitEl.addEventListener('change', function() {
    if (circuitEl.value) {
      direction = 'asc';
      descIcon.classList.add('hidden');
      ascIcon.classList.remove('hidden');
    }
    applyFilters();
  });
  sortEl.addEventListener('change', function() {
    if (sortEl.value === 'distance' && userLat === null) {
      navigator.geolocation.getCurrentPosition(
        function(pos) { userLat = pos.coords.latitude; userLng = pos.coords.longitude; applyFilters(); },
        function() { sortEl.value = 'popularity'; applyFilters(); }
      );
      return;
    }
    applyFilters();
  });
  dirBtn.addEventListener('click', function() {
    direction = direction === 'desc' ? 'asc' : 'desc';
    descIcon.classList.toggle('hidden', direction === 'asc');
    ascIcon.classList.toggle('hidden', direction === 'desc');
    applyFilters();
  });

  applyFilters();
})();
</script>
